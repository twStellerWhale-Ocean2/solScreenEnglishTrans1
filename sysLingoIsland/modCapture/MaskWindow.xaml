<Window x:Class="LingoIsland.Capture.MaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="#01000000"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize" Cursor="Cross"
        WindowStartupLocation="Manual">
  <Grid>
    <!-- 凍結畫格快照（不透明背景、畫面靜止，Issue #90）；上疊 45% 黑淡化維持變暗視覺 -->
    <Image x:Name="BgImage" Stretch="Fill"/>
    <Rectangle Fill="#73000000"/>
    <Canvas x:Name="RootCanvas" Background="Transparent">
      <Rectangle x:Name="SelRect" Stroke="#4C8DFF" StrokeThickness="2" Fill="#22FFFFFF"
                 Visibility="Collapsed"/>
      <Border x:Name="HintBorder" Background="#D2141A20" BorderBrush="#3C4043"
              BorderThickness="1" CornerRadius="12" Padding="12,5">
        <TextBlock Foreground="#E8EAED" FontSize="12">
          Drag to select the text to look up, or <Run Foreground="#8AB4F8">double-click</Run> to translate the line at the cursor. <Run Foreground="#8AB4F8">ESC</Run> to cancel
        </TextBlock>
      </Border>
    </Canvas>
  </Grid>
</Window>
