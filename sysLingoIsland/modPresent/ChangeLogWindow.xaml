<Window x:Class="LingoIsland.Present.ChangeLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Log" Width="560" Height="620"
        MinWidth="380" MinHeight="300"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{StaticResource PinkBg}">
  <!-- About 頁「Change Log」按鈕跳出之獨立更新紀錄視窗（#159）：沿用嵌入 CHANGELOG.md、唯讀可捲動可選取 -->
  <Border Style="{StaticResource Card}" Margin="12" Padding="12">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <TextBlock Grid.Row="0" Text="Change Log" FontWeight="SemiBold"
                 Foreground="{StaticResource PinkText}" FontSize="15" Margin="0,0,0,8"/>
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <TextBox x:Name="ChangeLogBox" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                 TextWrapping="Wrap" FontSize="12" Foreground="#3A2C33" IsTabStop="False" Padding="0"/>
      </ScrollViewer>
      <Button Grid.Row="2" x:Name="CloseBtn" Content="Close" Style="{StaticResource GhostButton}"
              HorizontalAlignment="Right" Margin="0,10,0,0"/>
    </Grid>
  </Border>
</Window>
