<UserControl x:Class="LingoIsland.Present.ResultView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="Transparent">
  <UserControl.Resources>
    <!-- 導航圓鈕（複查回饋）：啟用＝粉底深字圓鈕、hover 加深；停用＝淡底淡字、無手形——明確區分可用/不可用 -->
    <Style x:Key="NavButton" TargetType="Button">
      <Setter Property="Width" Value="30"/>
      <Setter Property="Height" Value="30"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Foreground" Value="#6D3A4D"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bg" CornerRadius="15" Background="#F4C2D0" BorderBrush="#E48CA8" BorderThickness="1.2">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bg" Property="Background" Value="#ECA6BC"/>
                <Setter TargetName="bg" Property="BorderBrush" Value="#D66C90"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="bg" Property="Background" Value="#F6ECF0"/>
                <Setter TargetName="bg" Property="BorderBrush" Value="#EBDBE2"/>
                <Setter Property="Foreground" Value="#DFCAD3"/>
                <Setter Property="Cursor" Value="Arrow"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>
  <!-- 查詢結果檢視（自 ResultWindow 抽出為共用 UserControl，#135）：三區直排原文／KK 音標／中譯，
       逐字可點查單字、鉛筆編輯重譯、中英各自播放/自動播放、加入我的筆記＋底色。宿於 Dictionary 分頁。 -->
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- 頂部工具列（導航/編輯/加入至） -->
      <RowDefinition Height="Auto"/>  <!-- 手動查詢輸入列（v1.0.1：兩列對調，移到頂部工具列下方，USR 回饋） -->
      <RowDefinition Height="*"/>      <!-- 內容區 -->
      <RowDefinition Height="Auto"/>  <!-- 底部工具列（加入我的筆記/底色） -->
    </Grid.RowDefinitions>

    <!-- 頂部工具列：往前/往後（單字查詢導航，快速返回原句）＋編輯（鉛筆）＋「加入至」資料夾 -->
    <Grid Grid.Row="0">
      <Border Height="1" Background="#F4C2D0" VerticalAlignment="Bottom"/>
      <StackPanel Orientation="Horizontal" Margin="14,8,16,8" VerticalAlignment="Center">
        <Button x:Name="BackBtn" Style="{StaticResource NavButton}" Content="&#xE76B;" ToolTip="Back (return to previous)"/>
        <Button x:Name="ForwardBtn" Style="{StaticResource NavButton}" Content="&#xE76C;" Margin="6,0,0,0" ToolTip="Forward"/>
        <Button x:Name="EditBtn" Style="{StaticResource NavButton}" Content="&#xE70F;" Margin="16,0,0,0"
                ToolTip="Edit the English text and re-translate"/>
        <TextBlock Text="Add to" VerticalAlignment="Center" Foreground="#8A5A6D" FontSize="12.5" Margin="16,0,6,0"/>
        <ComboBox x:Name="FolderCombo" MinWidth="110" MaxWidth="160" FontSize="12.5" VerticalAlignment="Center"/>
        <!-- 播音速度（v1.0.1，USR 回饋）：50–150% 下拉、每 10% 一階，套用於 Play／單字發音；session 內記憶（比照 AutoPlaySettings） -->
        <TextBlock Text="Speed" VerticalAlignment="Center" Foreground="#8A5A6D" FontSize="12.5" Margin="12,0,5,0"/>
        <ComboBox x:Name="SpeedCombo" AutomationProperties.AutomationId="SpeedCombo" Width="64" FontSize="12.5" VerticalAlignment="Center"
                  ToolTip="Playback speed for Play and word pronunciation (50–150%)">
          <ComboBoxItem Content="50%"/>
          <ComboBoxItem Content="60%"/>
          <ComboBoxItem Content="70%"/>
          <ComboBoxItem Content="80%"/>
          <ComboBoxItem Content="90%"/>
          <ComboBoxItem Content="100%" IsSelected="True"/>
          <ComboBoxItem Content="110%"/>
          <ComboBoxItem Content="120%"/>
          <ComboBoxItem Content="130%"/>
          <ComboBoxItem Content="140%"/>
          <ComboBoxItem Content="150%"/>
        </ComboBox>
      </StackPanel>
    </Grid>

    <!-- 手動查詢輸入列（v1.0.1：自 DictionaryPage 移入；USR 回饋「兩列對調」——頂部工具列在上、輸入列在下）。
         原生可編輯 ComboBox（不自訂 template）：下拉寬度＝輸入框（見 code-behind ConstrainDropDownWidth）；
         HorizontalContentAlignment=Stretch＋ItemTemplate 省略號：歷史整句過長時填滿寬度並以「…」截斷，不撐寬、不出水平捲軸 -->
    <Grid Grid.Row="1" Margin="14,10,14,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <ComboBox x:Name="InputBox" Grid.Column="0" FontSize="16" IsEditable="True"
                StaysOpenOnEdit="True" IsTextSearchEnabled="True" VerticalContentAlignment="Center"
                HorizontalContentAlignment="Stretch"
                ToolTip="Type English or pick from history, then Look up (Enter)">
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"/>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <Button x:Name="LookupBtn" Grid.Column="1" Content="Look up" Margin="8,0,0,0"
              Padding="16,5" FontSize="14" Style="{StaticResource GhostButton}"/>
    </Grid>

    <!-- 內容區：過長可捲動 -->
    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel x:Name="BodyPanel" Margin="18,14,18,10"/>
    </ScrollViewer>

    <!-- 底部工具列：加入我的筆記＋自動加入筆記＋底色色塊列 -->
    <Grid Grid.Row="3">
      <Border Height="1" Background="#F4C2D0" VerticalAlignment="Top"/>
      <StackPanel Margin="16,10,16,12">
        <StackPanel Orientation="Horizontal">
          <Button x:Name="AddNoteBtn" Cursor="Hand" ToolTip="Add to My Notes">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border x:Name="bg" CornerRadius="8" Background="#E9F6EE" BorderBrush="#C9E6D3"
                        BorderThickness="1" Padding="12,5">
                  <TextBlock Text="＋ Add to My Notes" FontSize="13.5" Foreground="#2F6F4A"/>
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bg" Property="Background" Value="#D9EFE0"/>
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Button.Template>
          </Button>
          <CheckBox x:Name="AutoAddChk" Content="Auto-add to Notes" Margin="14,0,0,0"
                    VerticalAlignment="Center" Foreground="#8A5A6D" FontSize="13"/>
        </StackPanel>
        <DockPanel Margin="0,8,0,0">
          <TextBlock DockPanel.Dock="Left" Text="Color" VerticalAlignment="Center" Foreground="#8A5A6D" FontSize="12.5" Margin="0,0,6,0"/>
          <WrapPanel x:Name="SwatchRow" Orientation="Horizontal" VerticalAlignment="Center"/>
        </DockPanel>
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
