<UserControl x:Class="LingoIsland.Present.ThemeManagementPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- 統一版面（#169，比照截圖/影片頁）：左＝主題清單（New Theme 置頂、右鍵/Delete 刪）｜右＝編輯區內容卡片 -->
  <Grid Margin="10">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="216" MinWidth="160"/>
      <ColumnDefinition Width="Auto"/>
      <ColumnDefinition Width="*" MinWidth="260"/>
    </Grid.ColumnDefinitions>

    <!-- 左：Themes 標題＋New Theme（置頂）＋清單 -->
    <Grid Grid.Column="0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <Grid Grid.Row="0">
        <TextBlock Text="主題" FontWeight="Bold" FontSize="13"
                   Foreground="{StaticResource PinkText}" VerticalAlignment="Center"/>
        <Button x:Name="AddBtn" Content="＋ 新增主題" Style="{StaticResource GhostButton}" HorizontalAlignment="Right"/>
      </Grid>
      <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,6,0,0">
        <ListBox x:Name="List" BorderThickness="0" Background="Transparent" Margin="4"
                 HorizontalContentAlignment="Stretch" ToolTip="右鍵點按或按 Delete 鍵以移除"/>
      </Border>
    </Grid>

    <GridSplitter Grid.Column="1" Style="{StaticResource ColSplitter}"/>

    <!-- 右：編輯區（內容卡片；描述框隨空間加高、動作鈕釘底、空間不足捲動） -->
    <Border Grid.Column="2" Style="{StaticResource Card}" Margin="6,0,0,0" Padding="12">
      <Grid>
        <ScrollViewer x:Name="EditorScroll" VerticalScrollBarVisibility="Auto">
          <Grid x:Name="Editor" MinHeight="{Binding ViewportHeight, ElementName=EditorScroll}">
            <!-- USR：圖片區移至最上、移除 Search keywords 欄 -->
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>  <!-- 自動解釋圖片鈕 -->
              <RowDefinition Height="Auto"/>  <!-- 圖片卡 -->
              <RowDefinition Height="Auto"/>  <!-- 名稱 -->
              <RowDefinition Height="Auto"/>  <!-- 描述 label -->
              <RowDefinition Height="*"/>     <!-- DescBox 成長 -->
              <RowDefinition Height="Auto"/>  <!-- 自動屏蔽字串（#217） -->
              <RowDefinition Height="Auto"/>  <!-- 配色規則 -->
              <RowDefinition Height="Auto"/>  <!-- 狀態列 -->
              <RowDefinition Height="Auto"/>  <!-- 動作鈕 -->
            </Grid.RowDefinitions>

            <Button Grid.Row="0" x:Name="DescribeBtn" Content="🔎 從圖片自動解釋" Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Right" Margin="0,0,0,8"/>

            <Border Grid.Row="1" x:Name="ImageDropCard" Style="{StaticResource Card}" Padding="8" Margin="0,0,0,8" AllowDrop="True">
              <StackPanel>
                <Image x:Name="Preview" MaxHeight="150" HorizontalAlignment="Left" Stretch="Uniform" Margin="0,0,0,6"/>
                <TextBlock x:Name="NoImageHint" Text="（尚無圖片；可貼上、上傳或拖曳圖片檔至此）"
                           Foreground="#9A6A82" FontSize="12" TextWrapping="Wrap"/>
                <Grid Margin="0,6,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Button x:Name="PasteBtn" Grid.Column="0" Content="從剪貼簿貼上" Style="{StaticResource GhostButton}" Margin="0,0,3,0"/>
                  <Button x:Name="UploadBtn" Grid.Column="1" Content="上傳檔案" Style="{StaticResource GhostButton}" Margin="3,0,0,0"/>
                </Grid>
              </StackPanel>
            </Border>

            <StackPanel Grid.Row="2">
              <TextBlock Text="名稱" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
              <TextBox x:Name="NameBox" Padding="6" Margin="0,4,0,10"/>
            </StackPanel>

            <TextBlock Grid.Row="3" Text="主題描述（作為查詢參考注入）" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
            <TextBox Grid.Row="4" x:Name="DescBox" Padding="6" Margin="0,4,0,4" TextWrapping="Wrap"
                     AcceptsReturn="True" MinHeight="80" VerticalAlignment="Stretch"
                     VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto"/>

            <!-- 自動屏蔽字串（#217）：主題描述之後、以 , 分隔；匯入字幕時自各句移除 -->
            <StackPanel Grid.Row="5" Margin="0,4,0,8">
              <TextBlock Text="自動屏蔽字串（匯入字幕時自動移除；以 , 分隔）" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
              <TextBox x:Name="BlockBox" Padding="6" Margin="0,4,0,0"
                       ToolTip="例：(SNORT), (LAUGHS)——之後匯入這個主題的字幕時，這些字串會自動從每句台詞移除；整句只剩屏蔽字串則整句剔除。已匯入的字幕不回溯（重新載入字幕即套用）。"/>
            </StackPanel>

            <Border Grid.Row="6" Style="{StaticResource Card}" Padding="8" Margin="0,0,0,8">
              <StackPanel>
                <TextBlock Text="顏色（12）— 點按色票即可更改" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
                <TextBlock Text="說明哪些說話人／字幕行使用各顏色（例：角色名稱）。用於字幕說話人文字色與筆記底色（自動調亮）。留空＝未使用。"
                           FontSize="11.5" Foreground="#9A6A82" Margin="0,2,0,6" TextWrapping="Wrap"/>
                <StackPanel x:Name="ColorRulesPanel"/>
              </StackPanel>
            </Border>

            <TextBlock Grid.Row="7" x:Name="StatusLine" Foreground="#2E7D46" FontSize="12" Margin="0,0,0,8"/>

            <WrapPanel Grid.Row="8">
              <Button x:Name="ActiveBtn" Content="設為使用中" Style="{StaticResource PinkButton}" Margin="0,0,8,0"/>
              <Button x:Name="SaveBtn" Content="儲存" Style="{StaticResource GhostButton}"/>
            </WrapPanel>
          </Grid>
        </ScrollViewer>
        <TextBlock x:Name="EmptyHint" Text="尚無主題。點按「＋ 新增主題」建立；輸入文字，或貼上／上傳遊戲截圖讓 AI 自動解釋。"
                   Foreground="#9A6A82" FontSize="13" TextWrapping="Wrap" MaxWidth="320"
                   TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
      </Grid>
    </Border>
  </Grid>
</UserControl>
