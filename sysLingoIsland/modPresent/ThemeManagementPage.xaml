<UserControl x:Class="LingoIsland.Present.ThemeManagementPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <!-- 主題管理（Issue #36；epic #145 增量2：自 Capture 頁獨立為「主題管理」頁）：整區為一個「Themes」區塊——標題其下含左命名主題清單與右編輯區 -->
    <Border Style="{StaticResource Card}" Padding="12" Margin="10">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>  <!-- Themes 區塊標題 -->
          <RowDefinition Height="*"/>      <!-- 左清單 | splitter | 右編輯區 -->
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Themes" FontWeight="Bold" FontSize="14"
                   Foreground="{StaticResource PinkText}" Margin="0,0,0,8"/>

        <!-- 左側主題清單欄寬可拖拉調整（Issue #58） -->
        <Grid Grid.Row="1">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="216" MinWidth="160"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*" MinWidth="260"/>
          </Grid.ColumnDefinitions>

          <!-- 左：命名主題清單（New Theme 於清單上方、統一 GhostButton；區塊標題已上移為整區標題） -->
          <Grid Grid.Column="0" Margin="0,0,4,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Button Grid.Row="0" x:Name="AddBtn" Content="＋ New Theme" Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Left" Margin="0,0,0,6"/>
            <Border Grid.Row="1" Style="{StaticResource Card}">
              <ListBox x:Name="List" BorderThickness="0" Background="Transparent" Margin="4"
                       HorizontalContentAlignment="Stretch"/>
            </Border>
          </Grid>

          <GridSplitter Grid.Column="1" Style="{StaticResource ColSplitter}"/>

          <!-- 右：編輯區（Issue #73：描述框隨空間加高、動作鈕釘底；空間不足時捲動） -->
          <Grid Grid.Column="2" Margin="6,0,0,0">
      <ScrollViewer x:Name="EditorScroll" VerticalScrollBarVisibility="Auto" Padding="4,0,4,0">
        <Grid x:Name="Editor" MinHeight="{Binding ViewportHeight, ElementName=EditorScroll}">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 名稱 label -->
            <RowDefinition Height="Auto"/>  <!-- NameBox -->
            <RowDefinition Height="Auto"/>  <!-- 描述 label -->
            <RowDefinition Height="*"/>     <!-- DescBox 成長 -->
            <RowDefinition Height="Auto"/>  <!-- 自動解釋圖片鈕（移至說明框尾端，v1.0.1） -->
            <RowDefinition Height="Auto"/>  <!-- 圖片卡 -->
            <RowDefinition Height="Auto"/>  <!-- 配色規則 -->
            <RowDefinition Height="Auto"/>  <!-- 狀態列 -->
            <RowDefinition Height="Auto"/>  <!-- 動作鈕 -->
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Text="Name" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
          <TextBox Grid.Row="1" x:Name="NameBox" Padding="6" Margin="0,4,0,10"/>

          <TextBlock Grid.Row="2" Text="Theme description (injected as reference for queries)" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
          <TextBox Grid.Row="3" x:Name="DescBox" Padding="6" Margin="0,4,0,4" TextWrapping="Wrap"
                   AcceptsReturn="True" MinHeight="80" VerticalAlignment="Stretch"
                   VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto"/>

          <!-- 自動解釋圖片鈕移至說明文字方塊尾端（v1.0.1）：以載入之圖片 vision 產描述、填入上方說明框 -->
          <Button Grid.Row="4" x:Name="DescribeBtn" Content="🔎 Auto-explain from Image" Style="{StaticResource GhostButton}"
                  HorizontalAlignment="Right" Margin="0,0,0,8"/>

          <!-- 圖片卡：支援拖放圖片檔（Issue #69）；貼上/上傳鈕各半填滿 -->
          <Border Grid.Row="5" x:Name="ImageDropCard" Style="{StaticResource Card}" Padding="8" Margin="0,0,0,8" AllowDrop="True">
            <StackPanel>
              <Image x:Name="Preview" MaxHeight="150" HorizontalAlignment="Left" Stretch="Uniform" Margin="0,0,0,6"/>
              <TextBlock x:Name="NoImageHint" Text="(No image yet; paste, upload, or drag an image file here)"
                         Foreground="#9A6A82" FontSize="12" TextWrapping="Wrap"/>
              <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="PasteBtn" Grid.Column="0" Content="Paste from Clipboard" Style="{StaticResource GhostButton}" Margin="0,0,3,0"/>
                <Button x:Name="UploadBtn" Grid.Column="1" Content="Upload File" Style="{StaticResource GhostButton}" Margin="3,0,0,0"/>
              </Grid>
            </StackPanel>
          </Border>

          <!-- 配色規則（Issue #69）：各色一格描述；台詞符合哪格即用該色、都不符合＝白 -->
          <Border Grid.Row="6" Style="{StaticResource Card}" Padding="8" Margin="0,0,0,8">
            <StackPanel>
              <TextBlock Text="Color rules (note background)" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
              <TextBlock Text="If a line matches a box's description, use that color; none matches = white. Leave a color blank to disable it."
                         FontSize="11.5" Foreground="#9A6A82" Margin="0,2,0,6" TextWrapping="Wrap"/>
              <StackPanel x:Name="ColorRulesPanel"/>
            </StackPanel>
          </Border>

          <TextBlock Grid.Row="7" x:Name="StatusLine" Foreground="#2E7D46" FontSize="12" Margin="0,0,0,8"/>

          <WrapPanel Grid.Row="8">
            <Button x:Name="ActiveBtn" Content="Set Active" Style="{StaticResource PinkButton}" Margin="0,0,8,0"/>
            <Button x:Name="SaveBtn" Content="Save" Style="{StaticResource GhostButton}" Margin="0,0,8,0"/>
            <Button x:Name="DeleteBtn" Content="Delete" Foreground="#B23B3B" Style="{StaticResource GhostButton}"/>
          </WrapPanel>
        </Grid>
      </ScrollViewer>
      <TextBlock x:Name="EmptyHint" Text="No themes yet. Click “+ New Theme” to create one; type text, or paste/upload a game screenshot for AI to auto-explain."
                 Foreground="#9A6A82" FontSize="13" TextWrapping="Wrap" MaxWidth="320"
                 TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
          </Grid>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</UserControl>
