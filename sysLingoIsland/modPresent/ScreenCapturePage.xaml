<UserControl x:Class="LingoIsland.Present.ScreenCapturePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- 版面統一（#182）：兩子頁籤【獲得】（擷取控制＋快速鍵）／【內容】（左清單｜右放大預覽）。以可見性切換 -->
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- 子頁籤：獲得 / 內容 -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
      <RadioButton x:Name="ShotTabAcquire" Style="{StaticResource SubTab}" GroupName="ShotTab" IsChecked="True" Content="獲得"/>
      <RadioButton x:Name="ShotTabContent" Style="{StaticResource SubTab}" GroupName="ShotTab" Content="內容"/>
    </StackPanel>

    <Grid Grid.Row="1">
      <!-- 【獲得】擷取控制（按鈕＋快速鍵設定） -->
      <Border x:Name="ShotAcquirePane" Style="{StaticResource Card}" Padding="12" VerticalAlignment="Top">
        <StackPanel>
          <TextBlock Text="Screen capture" FontWeight="Bold" FontSize="14" Foreground="{StaticResource PinkText}" Margin="0,0,0,8"/>
          <WrapPanel Orientation="Horizontal">
            <Button x:Name="CaptureScreenBtn" Content="Capture Screen" Style="{StaticResource GhostButton}" Margin="0,0,16,4"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,4">
              <TextBlock Text="Hotkey:" VerticalAlignment="Center" Foreground="{StaticResource PinkText}" Margin="0,0,4,0"/>
              <TextBlock x:Name="HotkeyStatus" MinWidth="80" VerticalAlignment="Center"
                         Foreground="{StaticResource PinkText}" FontWeight="SemiBold"/>
              <Button x:Name="ChangeHotkeyBtn" Content="Change" Style="{StaticResource GhostButton}" Margin="8,0,0,0"/>
            </StackPanel>
          </WrapPanel>
          <TextBlock Text="Capture a screen (button or hotkey); captured shots appear under the Content tab."
                     Foreground="{StaticResource PinkSub}" FontSize="12" TextWrapping="Wrap" Margin="0,10,0,0"/>
        </StackPanel>
      </Border>

      <!-- 【內容】左＝截圖清單（Clear all＋theme 篩選；右鍵/Delete 刪）｜右＝放大預覽 -->
      <Grid x:Name="ShotContentPane" Visibility="Collapsed">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="260" MinWidth="200"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*" MinWidth="240"/>
        </Grid.ColumnDefinitions>

        <!-- 左：Screenshots＋Clear all（置頂）＋依 theme 篩選＋清單 -->
        <Grid Grid.Column="0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Grid Grid.Row="0">
            <TextBlock Text="Screenshots" FontWeight="Bold" FontSize="13"
                       Foreground="{StaticResource PinkText}" VerticalAlignment="Center"/>
            <Button x:Name="ClearShotsBtn" Content="Clear all" Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Right"/>
          </Grid>
          <!-- 依 theme 篩選（圖文下拉，多媒體主題管理·B） -->
          <ComboBox x:Name="ShotThemeFilter" Grid.Row="1" Height="26" Margin="0,6,0,4"
                    VerticalContentAlignment="Center" ToolTip="Filter screenshots by theme"/>
          <Border Grid.Row="2" Style="{StaticResource Card}">
            <ListBox x:Name="ShotList" BorderThickness="0" Background="Transparent" Margin="4"
                     HorizontalContentAlignment="Stretch" ToolTip="Right-click or press Delete to remove"/>
          </Border>
        </Grid>

        <GridSplitter Grid.Column="1" Style="{StaticResource ColSplitter}"/>

        <!-- 右：內容區塊（所屬主題＋放大預覽） -->
        <Border Grid.Column="2" Style="{StaticResource Card}" Margin="6,0,0,0" Padding="6">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!-- 所屬主題（內容區塊上方；顯示/改指派選取截圖之主題，#173） -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4,2,4,6" VerticalAlignment="Center">
              <TextBlock Text="Theme:" VerticalAlignment="Center" Foreground="{StaticResource PinkText}" Margin="0,0,6,0"/>
              <ComboBox x:Name="ShotThemePicker" MinWidth="180" Height="26" VerticalContentAlignment="Center"
                        IsEnabled="False" ToolTip="Show / change the theme this screenshot belongs to"/>
            </StackPanel>
            <Grid Grid.Row="1">
              <Image x:Name="ShotPreview" Stretch="Uniform" Margin="6"/>
              <TextBlock x:Name="ShotEmptyHint" Text="No screenshots yet. Capture a screen (button or hotkey) to save it here."
                         Foreground="#9A6A82" FontSize="13" TextWrapping="Wrap" MaxWidth="260"
                         TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
