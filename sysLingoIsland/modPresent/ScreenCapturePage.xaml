<UserControl x:Class="LingoIsland.Present.ScreenCapturePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- 螢幕擷取控制 -->
      <RowDefinition Height="*"/>      <!-- 截圖管理（epic #145 增量3） -->
    </Grid.RowDefinitions>

    <!-- 螢幕截圖（epic #145 增量2）：兩種擷圖方式各一行——By button＝手動擷取鈕、By hotkey＝喚起快捷鍵。 -->
    <Border Grid.Row="0" Style="{StaticResource Card}" Padding="12" Margin="10,10,10,2">
      <StackPanel>
        <TextBlock Text="Screen capture" FontWeight="Bold" FontSize="14" Foreground="{StaticResource PinkText}"/>
        <Grid Margin="0,8,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="96"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Grid.Column="0" Text="By button" VerticalAlignment="Center" Foreground="{StaticResource PinkText}"/>
          <Button Grid.Row="0" Grid.Column="1" x:Name="CaptureScreenBtn" Content="Capture Screen"
                  Style="{StaticResource GhostButton}" HorizontalAlignment="Left"/>
          <TextBlock Grid.Row="1" Grid.Column="0" Text="By hotkey" VerticalAlignment="Center"
                     Foreground="{StaticResource PinkText}" Margin="0,8,0,0"/>
          <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
            <TextBlock x:Name="HotkeyStatus" MinWidth="90" VerticalAlignment="Center"
                       Foreground="{StaticResource PinkText}" FontWeight="SemiBold"/>
            <Button x:Name="ChangeHotkeyBtn" Content="Change" Style="{StaticResource GhostButton}" Margin="10,0,0,0"/>
          </StackPanel>
        </Grid>
      </StackPanel>
    </Border>

    <!-- 截圖管理（epic #145 增量3）：擷取之截圖保存於此，可檢視／刪除；標記擷取當下使用中主題 -->
    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12" Margin="10,2,10,10">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>  <!-- 標題＋Clear all -->
          <RowDefinition Height="*"/>      <!-- 左清單 | splitter | 右預覽 -->
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
          <TextBlock Text="Captured screenshots" FontWeight="Bold" FontSize="14" Foreground="{StaticResource PinkText}"/>
          <Button x:Name="ClearShotsBtn" Content="Clear all" Style="{StaticResource GhostButton}"
                  HorizontalAlignment="Right"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,8,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" MinWidth="180"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*" MinWidth="200"/>
          </Grid.ColumnDefinitions>

          <Border Grid.Column="0" Style="{StaticResource Card}">
            <ListBox x:Name="ShotList" BorderThickness="0" Background="Transparent" Margin="4"
                     HorizontalContentAlignment="Stretch"/>
          </Border>

          <GridSplitter Grid.Column="1" Style="{StaticResource ColSplitter}"/>

          <Grid Grid.Column="2" Margin="6,0,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Style="{StaticResource Card}">
              <Grid>
                <Image x:Name="ShotPreview" Stretch="Uniform" Margin="6"/>
                <TextBlock x:Name="ShotEmptyHint" Text="No screenshots yet. Capture a screen (button or hotkey) to save it here."
                           Foreground="#9A6A82" FontSize="13" TextWrapping="Wrap" MaxWidth="260"
                           TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Grid>
            </Border>
            <WrapPanel Grid.Row="1" Margin="0,8,0,0">
              <Button x:Name="DeleteShotBtn" Content="Delete" Foreground="#B23B3B"
                      Style="{StaticResource GhostButton}" IsEnabled="False"/>
            </WrapPanel>
          </Grid>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</UserControl>
