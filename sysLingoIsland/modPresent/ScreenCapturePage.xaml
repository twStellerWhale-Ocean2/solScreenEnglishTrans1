<UserControl x:Class="LingoIsland.Present.ScreenCapturePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <!-- 螢幕截圖（epic #145 增量2：自原 Capture 頁拆出獨立頁籤）：兩種擷圖方式各一行——By button＝手動擷取鈕、By hotkey＝喚起快捷鍵。 -->
    <Border Style="{StaticResource Card}" Padding="12" Margin="10" VerticalAlignment="Top">
      <StackPanel>
        <TextBlock Text="Screen capture" FontWeight="Bold" FontSize="14" Foreground="{StaticResource PinkText}"/>
        <Grid Margin="0,8,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="96"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Grid.Column="0" Text="By button" VerticalAlignment="Center" Foreground="{StaticResource PinkText}"/>
          <Button Grid.Row="0" Grid.Column="1" x:Name="CaptureScreenBtn" Content="Capture Screen"
                  Style="{StaticResource GhostButton}" HorizontalAlignment="Left"/>
          <TextBlock Grid.Row="1" Grid.Column="0" Text="By hotkey" VerticalAlignment="Center"
                     Foreground="{StaticResource PinkText}" Margin="0,8,0,0"/>
          <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
            <TextBlock x:Name="HotkeyStatus" MinWidth="90" VerticalAlignment="Center"
                       Foreground="{StaticResource PinkText}" FontWeight="SemiBold"/>
            <Button x:Name="ChangeHotkeyBtn" Content="Change" Style="{StaticResource GhostButton}" Margin="10,0,0,0"/>
          </StackPanel>
        </Grid>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
