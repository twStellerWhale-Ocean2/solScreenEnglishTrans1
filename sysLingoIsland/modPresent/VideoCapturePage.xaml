<UserControl x:Class="LingoIsland.Present.VideoCapturePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:local="clr-namespace:LingoIsland.Present"
             Background="Transparent">
  <UserControl.Resources>
    <!-- жЁҷжә–иЎЁж јжҺ§еҲ¶й … DataGrid дё»йЎҢпјҲ#177пјүпјҡйҖҸжҳҺеә•гҖҒзІүиЎЁй ӯгҖҒзҙ°еҲ—еҲҶйҡ”гҖҒзІүйҒёеҸ–пјӣж¬„еҸҜжӢ–жӣіиӘҝеҜ¬/жҺ’еәҸ/йҮҚжҺ’пјҲе…§е»әпјү -->
    <Style x:Key="GridColHeader" TargetType="DataGridColumnHeader">
      <Setter Property="Foreground" Value="#B0578D"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Background" Value="#22F4C2D0"/>
      <Setter Property="BorderBrush" Value="#33B0578D"/>
      <Setter Property="BorderThickness" Value="0,0,1,1"/>
      <Setter Property="Padding" Value="6,5"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style x:Key="GridRow" TargetType="DataGridRow">
      <Setter Property="Background" Value="Transparent"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#22B0578D"/></Trigger>
        <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="{StaticResource PinkTint}"/></Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="GridCell" TargetType="DataGridCell">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="Foreground" Value="#3A2C33"/>
      <Setter Property="Padding" Value="2,0"/>
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="Transparent"/>
          <Setter Property="Foreground" Value="#3A2C33"/>
        </Trigger>
      </Style.Triggers>
    </Style>
  </UserControl.Resources>
  <!-- зүҲйқўзөұдёҖпјҲ#182пјүпјҡе…©еӯҗй ҒзұӨгҖҗзҚІеҫ—гҖ‘пјҲй—ңйҚөеӯ—жҗңе°ӢпјӢзөҗжһңиЎЁж јпјӢз¶ІеқҖијүе…ҘпјүпјҸгҖҗе…§е®№гҖ‘пјҲе·ҰеҪұзүҮжё…е–®пҪңеҸіж’ӯж”ҫеҷЁпјӢйҖҗеҸҘеӯ—е№•пјүпјӢе…ұз”ЁзӢҖж…ӢеҲ— -->
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- еӯҗй ҒзұӨпјҡзҚІеҫ— / е…§е®№пјҲеҸҜиҰӢжҖ§еҲҮжҸӣпјҢйқһ TabControlпјҢйҒҝе…ҚеҲҮй ҒеҚёијүйҮҚе»ә WebView2 ж’ӯж”ҫеҷЁгҖҒдёӯж–·ж’ӯж”ҫпјү -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
      <RadioButton x:Name="SubTabSearch" Style="{StaticResource SubTab}" GroupName="VideoSubTab" IsChecked="True" Content="зҚІеҫ—"/>
      <RadioButton x:Name="SubTabPlay" Style="{StaticResource SubTab}" GroupName="VideoSubTab" Content="е…§е®№"/>
    </StackPanel>

    <!-- bodyпјҡе…© pane з–Ҡж”ҫеҗҢж јпјҢйқ еҸҜиҰӢжҖ§еҲҮжҸӣ -->
    <Grid Grid.Row="1">

      <!-- гҖҗзҚІеҫ—гҖ‘й—ңйҚөеӯ—жҗңе°ӢпјӢзөҗжһңиЎЁж јпјӢз¶ІеқҖијүе…Ҙ -->
      <Border x:Name="SearchPane" Style="{StaticResource Card}" Padding="12" VerticalAlignment="Top">
        <StackPanel>
          <TextBlock Text="Load a video" FontWeight="Bold" FontSize="14" Foreground="{StaticResource PinkText}" Margin="0,0,0,8"/>

          <!-- зӣҙжҺҘијүе…ҘпјҲepic #178 еўһйҮҸ6вҖІ ж ёеҝғпјүпјҡдҪҝз”ЁиҖ…е·ІзҹҘеҪұзүҮпјӢеӯ—е№•жӘ”з¶ІеқҖпјҢзӣҙжҺҘе»әз«Ӣеӯ—е№•вҖ”вҖ”з№һйҒҺдёҚз©©зҡ„ AI иҮӘеӢ•й…ҚзүҮ finderпјҢеҸҜйқ и·Ҝеҫ‘гҖӮ
               иө°иҲҮијүе…ҘзӣёеҗҢд№Ӣз®Ўз·ҡпјҲеҸ–еӯ—е№•жӘ”вҶ’ж•ҙзҗҶиӘӘи©ұдәәпјӢеҸ°и©һвҶ’Whisper еҸ–жҷӮй–“вҶ’йҖҗеҸҘе°ҚйҪҠпјүпјҢи·‘еүҚзўәиӘҚиІ»з”ЁгҖӮ -->
          <StackPanel x:Name="AcqPaneDirect" Margin="0,0,0,10">
            <TextBlock Text="Load a specific video (recommended)" FontWeight="SemiBold" Foreground="#B0578D" Margin="0,0,0,4"/>
            <TextBlock Text="Paste a YouTube link (or ID) and its subtitle-file URL (a transcript page that names the speakers). LingoIsland builds speaker subtitles timed to the real audio. Uses your OpenAI key; confirms cost first."
                       Foreground="#9A6A82" FontSize="11.5" TextWrapping="Wrap" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="Video" VerticalAlignment="Center" Width="56" Foreground="#B0578D"/>
              <TextBox x:Name="DirectVideoBox" Grid.Column="1" Height="30" VerticalContentAlignment="Center" Padding="6,0"
                       ToolTip="YouTube link or 11-character video ID"/>
            </Grid>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="Subtitle" VerticalAlignment="Center" Width="56" Foreground="#B0578D"/>
              <TextBox x:Name="DirectSubtitleBox" Grid.Column="1" Height="30" VerticalContentAlignment="Center" Padding="6,0"
                       ToolTip="URL of a transcript/subtitle page that names the speakers (e.g. a fandom transcript)"/>
              <Button x:Name="DirectBuildBtn" Grid.Column="2" Content="&#x2699; Build subtitles" Width="140" Height="30" Margin="8,0,0,0"/>
            </Grid>
          </StackPanel>

          <TextBlock Text="вҖ” or auto-find videos from a subtitle page (may miss) вҖ”" Foreground="#C89AB0" FontSize="10.5" Margin="0,0,0,8" HorizontalAlignment="Center"/>

          <!-- з”ұеӯ—е№•жӘ”з¶ІеқҖпјҲepic #178 еўһйҮҸ2пјҢ#182пјүпјҡиІјеӯ—е№•жӘ”з¶Із«ҷпјҸз¶ІеқҖвҶ’AI и§Јжһҗй©—иӯүеҗ«иӘӘи©ұдәәвҶ’й…Қ YouTubeпјҢжҲҗжһңеҲ—ж–јдёӢж–№жҲҗжһңеҚҖеЎҠгҖӮ
               з”Ё OpenAIпјҲgpt-4.1 web_searchпјүпјҢи·‘еүҚзўәиӘҚиІ»з”ЁгҖӮијёе…ҘеҸҜзӮәе–®дёҖеӯ—е№•жӘ”й Ғ жҲ– еҲ—еӨҡд»Ҫеӯ—е№•жӘ”йҖЈзөҗд№Ӣзӣ®йҢ„й ҒпјҲз«ҷеҸ°з„Ўй—ңпјүгҖӮ -->
          <StackPanel x:Name="AcqPaneTranscript">
            <TextBlock Text="Load videos from a subtitle page" FontWeight="SemiBold" Foreground="#B0578D" Margin="0,0,0,4"/>
            <TextBlock Text="Paste a subtitle-file URL вҖ” a single transcript page, or an index page that lists several. LingoIsland reads it, keeps the ones that name a speaker, and matches each to its YouTube video. Uses your OpenAI key; confirms cost first."
                       Foreground="#9A6A82" FontSize="11.5" TextWrapping="Wrap" Margin="0,0,0,6"/>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <!-- еӯ—е№•жӘ”з¶ІеқҖжЎҶпјҡеҸҜз·ЁијҜ ComboBoxпјҢдёӢжӢүйЎҜзӨәеӯ—е№•жӘ”з¶ІеқҖжӯ·еҸІпјҲжҜ”з…§й—ңйҚөеӯ—жЎҶ #186пјүпјӣвҶ‘вҶ“ йҒёгҖҒDelete еҲӘи©ІзӯҶ -->
              <ComboBox x:Name="TranscriptBox" Grid.Column="0" Height="30" IsEditable="True" StaysOpenOnEdit="True"
                        IsTextSearchEnabled="False" VerticalContentAlignment="Center" Padding="6,0"
                        ToolTip="Paste a subtitle-file URL (or pick from history); вҶ‘вҶ“ then Delete removes a history entry"/>
              <Button x:Name="TranscriptSearchBtn" Grid.Column="1" Content="&#x1F4C4; Find" Width="100" Height="30" Margin="8,0,0,0"/>
            </Grid>
            <!-- жүҫзүҮйҒёй …пјҲepic #178 еўһйҮҸ2пјҢ#182пјүпјҡFind up to NпјқдёҖж¬ЎжңҖеӨҡи§Јжһҗ/й©—иӯүе№ҫд»Ҫеӯ—е№•жӘ”пјҲиҠұйЎҚеәҰгҖҒжҺ§з®ЎзӯҶж•ёпјүпјӣSkip existingпјқжҝҫжҺүе·ІеңЁеҪұзүҮжё…е–®иҖ… -->
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0" VerticalAlignment="Center">
              <TextBlock Text="Find up to" VerticalAlignment="Center" Foreground="#B0578D"/>
              <ComboBox x:Name="FindMaxCount" Width="50" Height="26" Margin="4,0,0,0" VerticalContentAlignment="Center"
                        ToolTip="How many subtitle files to read and verify at most (each uses your OpenAI key)">
                <ComboBoxItem Content="3"/>
                <ComboBoxItem Content="5" IsSelected="True"/>
                <ComboBoxItem Content="10"/>
              </ComboBox>
              <CheckBox x:Name="SkipExistingVideos" Content="Skip videos I already have" IsChecked="False" VerticalAlignment="Center"
                        Foreground="#B0578D" Margin="16,0,0,0"
                        ToolTip="Leave out matches that are already in your Videos list"/>
            </StackPanel>
          </StackPanel>

          <!-- жҲҗжһңеҚҖеЎҠпјҲ#189пјүпјҡз”ұй—ңйҚөеӯ—пјҸз”ұйҖҗеӯ—зЁҝд№Ӣжҗңе°ӢзөҗжһңзөұдёҖеҲ—ж–јжӯӨпјӣжЁҷжә–иЎЁж ј DataGridпјҲ#177пјҢж¬„еҸҜиӘҝеҜ¬/йҮҚжҺ’гҖҒй»һиЎЁй ӯжҺ’еәҸзҡҶе…§е»әпјӣдёҠж–№йҒҺжҝҫжЎҶ + йҖҗеҲ— Load йҲ•пјү -->
          <Border x:Name="SearchResultsPanel" Visibility="Collapsed" Margin="0,6,0,0"
                  BorderBrush="#33B0578D" BorderThickness="1" CornerRadius="6" Background="#40FFFFFF">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <!-- йҒҺжҝҫпјҲдҫқжЁҷйЎҢеҚіжҷӮзҜ©йҒёпјҢ#177пјү -->
              <Grid Grid.Row="0" Margin="8,6,8,4">
                <TextBox x:Name="ResultFilterBox" Height="26" VerticalContentAlignment="Center" Padding="6,0"
                         Background="#66FFFFFF" TextChanged="OnResultFilterChanged" ToolTip="Filter results by title"/>
                <TextBlock x:Name="FilterPlaceholder" Text="&#x1F50D; Filter by titleвҖҰ" Foreground="#9A6A82" FontSize="11.5"
                           Margin="8,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
              </Grid>
              <!-- жЁҷжә–иЎЁж ј DataGridпјҲ#177пјүпјҡж¬„еҸҜжӢ–жӣіиӘҝеҜ¬/йҮҚжҺ’гҖҒй»һиЎЁй ӯжҺ’еәҸзҡҶе…§е»әпјӣзҜ©йҒёжІҝз”ЁдёҠж–№йҒҺжҝҫжЎҶпјҲListCollectionView.Filterпјүпјӣйӣҷж“ҠеҲ—дәҰијүе…Ҙ -->
              <DataGrid x:Name="SearchResultsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                        HeadersVisibility="Column" CanUserResizeColumns="True" CanUserReorderColumns="True"
                        CanUserSortColumns="True" CanUserResizeRows="False" CanUserAddRows="False" CanUserDeleteRows="False"
                        SelectionMode="Single" SelectionUnit="FullRow" GridLinesVisibility="Horizontal"
                        HorizontalGridLinesBrush="#22B0578D" Background="Transparent" RowBackground="Transparent"
                        BorderThickness="0" MaxHeight="500" RowHeight="44" FontSize="12"
                        HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                        PreviewMouseRightButtonDown="OnResultRowRightClick"
                        ColumnHeaderStyle="{StaticResource GridColHeader}" RowStyle="{StaticResource GridRow}" CellStyle="{StaticResource GridCell}">
                <!-- еҸійҚөйҮҚж–°жӘўжҹҘпјҲ#188пјүпјҡеӯ—е№•зӢҖж…Ӣе·Іеҝ«еҸ–гҖҒе№іеёёйҮҚжҗңзӣҙжҺҘйӮ„еҺҹдёҚйҮҚжҺўпјӣйңҖжӣҙж–°жҷӮж–јжӯӨжүӢеӢ•йҮҚжӘўпјҲе…§еөҢе…ҚиІ»гҖҒз¶Іи·ҜиҠұйЎҚеәҰпјү -->
                <DataGrid.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="вҶ» Re-check embedded subtitles (free)" Click="OnRecheckEmbedded"/>
                    <MenuItem Header="рҹҢҗ Re-check web subtitle (uses OpenAI)" Click="OnRecheckWeb"/>
                  </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                  <!-- жҺЁи–Ұе„ӘеәҸпјҲ#183пјүпјҡеҪ©иүІең“жЁҷж•ёеӯ— 1вҖ“5пјҲ5пјқжңҖдҪігҖҒз¶ пјӣ3пјқзҗҘзҸҖпјӣдҪҺпјқзҒ°пјүвҖ”вҖ”жҜ”жҳҹзӯүеҘҪжҮӮпјӣй»һиЎЁй ӯд»ҘжҺЁи–ҰеҲҶжҺ’еәҸпјҲй җиЁӯжҺ’еәҸж¬„пјү -->
                  <DataGridTemplateColumn Header="Pick" SortMemberPath="RecommendScore" CanUserResize="False" MinWidth="48">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <Border Background="{Binding RecommendBrush}" CornerRadius="10" Width="22" Height="22"
                                HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="{Binding RecommendTip}">
                          <TextBlock Text="{Binding RecommendLabel}" Foreground="White" FontWeight="Bold" FontSize="11.5"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <!-- зё®ең– -->
                  <DataGridTemplateColumn Header="" CanUserSort="False" CanUserResize="False" Width="64">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <Image Source="{Binding ThumbSource}"
                               Width="{Binding ThumbWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Height="{Binding ThumbHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Stretch="UniformToFill" VerticalAlignment="Center"/>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <!-- еҗҚзЁұпјҲжҺ’еәҸ AвҖ“ZпјӣеҸҜиӘҝеҜ¬пјӣдҪ”ж»ҝеү©йӨҳеҜ¬пјү -->
                  <DataGridTextColumn Header="Title" Binding="{Binding Title}" SortMemberPath="Title" Width="*" MinWidth="140">
                    <DataGridTextColumn.ElementStyle>
                      <Style TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        <Setter Property="ToolTip" Value="{Binding Title}"/>
                      </Style>
                    </DataGridTextColumn.ElementStyle>
                  </DataGridTextColumn>
                  <!-- зүҮй•·пјҲжҺ’еәҸйҚөпјқз§’ж•ё DurationSecпјү -->
                  <DataGridTextColumn Header="Time" Binding="{Binding DurationText}" SortMemberPath="DurationSec" MinWidth="48">
                    <DataGridTextColumn.ElementStyle>
                      <Style TargetType="TextBlock">
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Foreground" Value="#6D3A4D"/>
                      </Style>
                    </DataGridTextColumn.ElementStyle>
                  </DataGridTextColumn>
                  <!-- еҲқж¬Ўжҗңе°ӢжҷӮй–“пјҲ#186пјүпјҡyyyy-MM-dd HH:mmпјҢеӯ—дёІеҚіжҢүжҷӮй–“жҺ’еәҸ -->
                  <DataGridTextColumn Header="First seen" Binding="{Binding FirstSeen}" SortMemberPath="FirstSeen" MinWidth="96">
                    <DataGridTextColumn.ElementStyle>
                      <Style TargetType="TextBlock">
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Foreground" Value="#9A6A82"/>
                        <Setter Property="FontSize" Value="11"/>
                      </Style>
                    </DataGridTextColumn.ElementStyle>
                  </DataGridTextColumn>
                  <!-- йҖЈзөҗпјҲй–Ӣ YouTube еҺҹй Ғпјү -->
                  <DataGridTemplateColumn Header="Link" CanUserSort="False" CanUserResize="False" MinWidth="56">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center">
                          <Hyperlink NavigateUri="{Binding WatchUri}" RequestNavigate="OnOpenExternalLink" ToolTip="{Binding WatchUrl}">YouTube &#x2197;</Hyperlink>
                        </TextBlock>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <!-- дёүзЁ®еӯ—е№•зӢҖж…ӢпјҲжҺ’еәҸйҚөпјқRankпјӣManualз¶ пјҸAutoзҗҘзҸҖе…ҚиІ»иҮӘеӢ•еЎ«гҖҒWebи—ҚйҖҗеҲ—жҢүйңҖжҹҘпјү -->
                  <DataGridTemplateColumn Header="Manual" SortMemberPath="ManualRank" CanUserResize="False" MinWidth="52">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                          <local:Spinner Width="14" Height="14" Foreground="#B0578D" Visibility="{Binding EmbeddedSpinnerVisibility}"/>
                          <TextBlock Text="{Binding ManualText}" Foreground="{Binding ManualBrush}" FontWeight="SemiBold"
                                     FontSize="12.5" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Human-made subtitles"/>
                        </Grid>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTemplateColumn Header="Auto" SortMemberPath="AutoRank" CanUserResize="False" MinWidth="46">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                          <local:Spinner Width="14" Height="14" Foreground="#B0578D" Visibility="{Binding EmbeddedSpinnerVisibility}"/>
                          <TextBlock Text="{Binding AutoText}" Foreground="{Binding AutoBrush}" FontWeight="SemiBold"
                                     FontSize="12.5" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Auto-generated captions"/>
                        </Grid>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTemplateColumn Header="Web" SortMemberPath="WebRank" CanUserResize="False" MinWidth="64">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                          <Button Content="{Binding WebButtonText}" IsEnabled="{Binding WebButtonEnabled}" Visibility="{Binding WebButtonVisibility}"
                                  Click="OnSearchRowWebProbe" Background="Transparent" BorderBrush="#66B0578D" BorderThickness="1"
                                  FontSize="11" Padding="6,2" Cursor="Hand"
                                  ToolTip="Check the web for a transcript (uses your OpenAI key; costs a small fee)"/>
                          <local:Spinner Width="14" Height="14" Foreground="#1565C0" Visibility="{Binding WebCheckingVisibility}"/>
                          <TextBlock Text="{Binding WebResultText}" Foreground="{Binding WebResultBrush}" Visibility="{Binding WebResultVisibility}"
                                     FontSize="12.5" FontWeight="SemiBold" VerticalAlignment="Center" ToolTip="{Binding WebResultTip}"/>
                        </Grid>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <!-- ијүе…ҘйҲ•пјҲ#183пјҡз§»еҲ°иЎҢе°ҫпјүпјҡе”ҜдёҖијүе…Ҙж–№ејҸпјҲе·ІеҸ–ж¶Ҳйӣҷж“Ҡијүе…Ҙпјүпјӣе·ІеңЁжё…е–®иҖ…еҒңз”ЁгҖҒжЁҷгҖҢAddedгҖҚзҒ° -->
                  <DataGridTemplateColumn Header="Load" CanUserSort="False" CanUserResize="False" MinWidth="58">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <Button Content="{Binding LoadText}" IsEnabled="{Binding CanLoad}" Click="OnSearchRowLoad"
                                Padding="10,3" Margin="2" Cursor="Hand" VerticalAlignment="Center"
                                ToolTip="Load this video into the player (disabled if already in your Videos list)"/>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                </DataGrid.Columns>
              </DataGrid>
            </Grid>
          </Border>
        </StackPanel>
      </Border>

      <!-- гҖҗе…§е®№гҖ‘е·ҰпјқеҪұзүҮжё…е–®пјҲClear allпјӢtheme зҜ©йҒёпјӣеҸійҚө/Delete еҲӘпјүпҪңеҸіпјқж’ӯж”ҫеҷЁпјӢйҖҗеҸҘеӯ—е№•пјҲй җиЁӯйҡұи—ҸпјҢијүе…ҘеҪұзүҮжҷӮиҮӘеӢ•еҲҮжҸӣиҮіжӯӨпјү -->
      <Grid x:Name="PlayPane" Visibility="Collapsed">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="200" MinWidth="150"/>
          <ColumnDefinition Width="6"/>
          <ColumnDefinition Width="*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <!-- е·ҰпјҡVideosпјӢClear allпјҲзҪ®й ӮпјүпјӢдҫқ theme зҜ©йҒёпјӢжё…е–® -->
        <Grid Grid.Column="0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Grid Grid.Row="0">
            <TextBlock Text="Videos" FontWeight="Bold" FontSize="13" Foreground="{StaticResource PinkText}" VerticalAlignment="Center"/>
            <Button x:Name="ClearVideosBtn" Content="Clear all" Style="{StaticResource GhostButton}" HorizontalAlignment="Right"/>
          </Grid>
          <!-- дҫқ theme зҜ©йҒёпјҲең–ж–ҮдёӢжӢүпјҢеӨҡеӘ’й«”дё»йЎҢз®ЎзҗҶВ·Bпјү -->
          <ComboBox x:Name="VideoThemeFilter" Grid.Row="1" Height="26" Margin="0,6,0,4"
                    VerticalContentAlignment="Center" ToolTip="Filter videos by theme"/>
          <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
              <ListBox x:Name="VideoList" BorderThickness="0" Background="Transparent" Margin="4"
                       HorizontalContentAlignment="Stretch"
                       ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                       ToolTip="Click to load; right-click or press Delete to remove"/>
              <TextBlock x:Name="VideoEmptyHint" Text="No videos yet. Paste a subtitle-file URL under Acquire."
                         Foreground="#9A6A82" FontSize="12" TextWrapping="Wrap" MaxWidth="160"
                         TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
          </Border>
        </Grid>

        <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="Transparent"/>

        <!-- еҸіпјҡе…§е®№еҚҖеЎҠпјҲжүҖеұ¬дё»йЎҢпјӢж’ӯж”ҫдёӯз¶ІеқҖпјӢж’ӯж”ҫеҷЁпҪңйҖҗеҸҘеӯ—е№•пјү -->
        <Border Grid.Column="2" Style="{StaticResource Card}" Padding="8">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- жүҖеұ¬дё»йЎҢпјҲе…§е®№еҚҖеЎҠдёҠж–№пјӣйЎҜзӨә/ж”№жҢҮжҙҫзӣ®еүҚеҪұзүҮд№Ӣдё»йЎҢпјҢ#173пјүпјӢж’ӯж”ҫдёӯеҪұзүҮи¶…йҖЈзөҗз¶ІеқҖпјҲ#177пјү -->
            <StackPanel Grid.Row="0" Margin="2,0,2,8">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Theme:" VerticalAlignment="Center" Foreground="{StaticResource PinkText}" Margin="0,0,6,0"/>
                <ComboBox x:Name="VideoThemePicker" MinWidth="180" Height="26" VerticalContentAlignment="Center"
                          IsEnabled="False" ToolTip="Show / change the theme this video belongs to"/>
              </StackPanel>
              <!-- еҪұзүҮжЁҷйЎҢпјҲ#187пјӣ#189 ж”№е”Ҝи®Җ TextBox дҪҝеҸҜйҒёеҸ–пјҸиӨҮиЈҪпјүпјҡзҪ®ж–јз¶ІеқҖд№ӢдёҠпјӣијүе…ҘеҚійЎҜпјҲе…Ҳз”Ёжё…е–®жЁҷйЎҢпјҢиө·ж’ӯеҫҢд»Ҙж’ӯж”ҫеҷЁеҜҰеҗҚжӣҙж–°пјү -->
              <TextBox x:Name="VideoTitleText" Margin="0,6,0,0" FontWeight="SemiBold" FontSize="13.5"
                       Foreground="{StaticResource PinkText}" TextWrapping="Wrap" Visibility="Collapsed"
                       IsReadOnly="True" IsReadOnlyCaretVisible="False" BorderThickness="0" Background="Transparent"
                       Padding="0" Cursor="IBeam" ToolTip="еҪұзүҮжЁҷйЎҢпјҲеҸҜйҒёеҸ–пјҸиӨҮиЈҪпјү"/>
              <!-- ж’ӯж”ҫдёӯеҪұзүҮд№Ӣи¶…йҖЈзөҗз¶ІеқҖпјҲ#177пјүпјҡеҸҜй»һй–Ӣ YouTube еҺҹй Ғпјӣз„Ўијүе…ҘжҷӮйҡұи—Ҹ -->
              <TextBlock x:Name="WatchUrlRow" Margin="0,3,0,0" FontSize="11.5" Foreground="#9A6A82"
                         Visibility="Collapsed" TextTrimming="CharacterEllipsis">
                <Run Text="URL: "/><Hyperlink x:Name="WatchUrlLink" RequestNavigate="OnOpenExternalLink"
                         Foreground="{StaticResource PinkText}"><Run x:Name="WatchUrlText"/></Hyperlink>
              </TextBlock>
            </StackPanel>

            <Grid Grid.Row="1">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="260"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="230" MinWidth="150"/>
              </Grid.ColumnDefinitions>

            <!-- дёӯпјҡж’ӯж”ҫеҷЁпјӢз•¶еүҚеҸҘеӯ—е№•её¶пјӢжҺ§еҲ¶ -->
            <Grid Grid.Column="0">
              <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="120"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>

              <Border Grid.Row="0" Background="Black" CornerRadius="6" ClipToBounds="True">
                <Grid>
                  <wv2:WebView2 x:Name="Web"/>
                  <!-- ијүе…Ҙзӯүеҫ…еӢ•з•«пјҲ#186пјүпјҡијүе…Ҙдёӯж”¶иө· WebView2пјҲйҒҝ airspace йҒ®дҪҸпјүгҖҒж–јй»‘еә•йЎҜж—ӢиҪүжІҷжјҸ -->
                  <StackPanel x:Name="LoadOverlay" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <local:Spinner Width="48" Height="48" Foreground="White"/>
                    <TextBlock Text="LoadingвҖҰ" Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0" FontSize="13"/>
                  </StackPanel>
                </Grid>
              </Border>

              <Border Grid.Row="1" Background="#88FFFFFF" BorderBrush="#F4C2D0" BorderThickness="1" CornerRadius="6"
                      Margin="0,8,0,0" Padding="10" MinHeight="52">
                <!-- еӯ—зҙҡ/зІ—й«”з”ұ SubtitleDisplaySettings ж–ј ApplySubtitleDisplay() еҘ—з”ЁпјҲиЁӯе®ҡеҸҜиӘҝпјҢжҜ”з…§зӯҶиЁҳпјүпјӣж–Үеӯ—иүІжҜ”з…§зӯҶиЁҳжўқзӣ® #3A2C33гҖӮй»һеӯ—жҹҘи©һпјӣеҸійҚөиӨҮиЈҪж•ҙеҸҘпјҲ#189пјҢеӯ—еҸҜй»һж•…д»ҘеҸійҚөиӨҮиЈҪеҸ–д»ЈжӢ–йҒёпјү -->
                <TextBlock x:Name="SubtitleBand" TextWrapping="Wrap" Foreground="#3A2C33">
                  <TextBlock.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="Copy line" Click="OnCopySubtitleLine"/>
                    </ContextMenu>
                  </TextBlock.ContextMenu>
                </TextBlock>
              </Border>

              <WrapPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                <Button x:Name="ReplayBtn" Content="&#x23EE; Replay" Width="92" Height="28" Margin="0,0,6,4" IsEnabled="False"/>
                <Button x:Name="ResumeBtn" Content="&#x25B6; Continue" Width="96" Height="28" Margin="0,0,6,4" IsEnabled="False"/>
                <Button x:Name="NextBtn" Content="&#x23ED; Next" Width="84" Height="28" Margin="0,0,6,4" IsEnabled="False"/>
                <Button x:Name="AddNoteBtn" Content="&#xFF0B; Add to Notes" Width="132" Height="28" Margin="10,0,0,4" IsEnabled="False"/>
                <!-- жҢҮе®ҡиӘӘи©ұдәәжүҚжҡ«еҒңпјҲеўһйҮҸ7пјү -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,4">
                  <TextBlock Text="Pause at:" VerticalAlignment="Center" Foreground="#B0578D" Margin="0,0,4,0"/>
                  <ComboBox x:Name="PauseAtSpeaker" MinWidth="110" Height="26" VerticalContentAlignment="Center"
                            IsEnabled="False" ToolTip="Only pause at this speaker's lines (others play through)"/>
                </StackPanel>
              </WrapPanel>
            </Grid>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- еҸіпјҡиӘӘи©ұдәәзҜ©йҒёпјӢдҫҶжәҗз–ҠеҠ пјӢйҖҗеҸҘеӯ—е№•жё…е–®пјҲй»һи·іпјүпјҸж•ҙжӘ” YAML з·Ёдҝ® -->
            <Grid Grid.Column="2">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>

              <!-- иӘӘи©ұдәәзҜ©йҒёпјҲ#189пјҡз§»еҲ°еӯ—е№•жё…е–®жӯЈдёҠж–№пјү -->
              <ComboBox x:Name="SpeakerFilter" Grid.Row="1" Height="26" VerticalContentAlignment="Center" Margin="0,2,0,4"
                        IsEnabled="False" ToolTip="Filter the subtitle list by speaker"/>

              <Grid Grid.Row="0" Margin="0,0,0,2">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- в‘  еҲқе§ӢиіҮж–ҷпјҲ#189пјүпјҡеӯ—е№•**дҫҶжәҗ**вҖ”вҖ”еғ…йЎҜзӨәпјҲдёҚеҸҜж“ҚдҪңпјҢйҒҝе…ҚиӘӨжңғеҸҜеҲҮжҸӣпјүгҖӮManualпјқдәәе·Ҙеӯ—е№•пјҲжҷӮй–“+ж–·еҸҘзҡҶжә–пјүгҖҒAutoпјқиҮӘеӢ•еӯ—е№•пјҲжҷӮй–“жә–гҖҒж–·еҸҘеҸҜиғҪйҢҜпјүпјӣзҡҶз„Ўи¬ӣи©ұдәә -->
                <Grid Grid.Row="0" Height="26">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="26"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="&#x1F4AC;" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"
                             ToolTip="иҮӘеҪұзүҮдҫҶжәҗзҚІеҫ—еӯ—е№•пјҲеғ…йЎҜзӨәдҫҶжәҗпјүгҖӮ"/>
                  <TextBlock x:Name="BaseSourceText" Grid.Column="1" VerticalAlignment="Center" Foreground="#6D3A4D"
                             FontSize="12.5" Margin="2,0,0,0"
                             ToolTip="еӯ—е№•дҫҶжәҗпјҡManualпјқдәәе·Ҙеӯ—е№•пјҲжңҖдҪіпјүгҖҒAutoпјқиҮӘеӢ•еӯ—е№•гҖӮйҖҷжҳҜжң¬зүҮеҜҰйҡӣеҸ–еҫ—зҡ„дҫҶжәҗпјҢеғ…дҫӣйЎҜзӨәгҖӮ"/>
                </Grid>
                <!-- в‘Ў зІҫдҝ®жҷӮй–“пјҲ#189пјӣ#180 з§»йҷӨеҺҹгҖҢи¬ӣи©ұдәәпјҸж–·еҸҘгҖҚрҹҢҗScript/рҹ§ AI йӮЈеҲ—пјүпјҡрҹҺҷ VoiceпјқжҠ“йҹіжӘ”жҠҠжҷӮй–“е°ҚеҲ°зңҹеҜҰзҷјйҹіпјҲAuto еҹәеә•еҸҰиЈңж–·еҸҘпјүгҖӮеҸ–д»ЈеҺҹгҖҢRe-transcribeгҖҚ -->
                <Grid Grid.Row="1" Margin="0,4,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="26"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="&#x23F1;" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"
                             ToolTip="жЁҷзӨәжҷӮй–“пјҢиӢҘзӮә Auto йӮ„еўһеҠ дҝ®иЁӮж–·еҸҘгҖӮ"/>
                  <Button x:Name="TranscribeBtn" Grid.Column="1" Grid.ColumnSpan="2" Content="&#x1F399; Voice" Height="26" Margin="0,0,0,0"
                          IsEnabled="False" ToolTip="Transcribe the actual audio (OpenAI Whisper) to refine the timing to the real speech. Downloads audio; confirms cost first."/>
                </Grid>
                <!-- в‘ў й–Ӣе•ҹжң¬зүҮиіҮж–ҷеӨҫпјҲ#189пјҢрҹ“ҒпјүпјӢж•ҙжӘ” YAML з·Ёдҝ®пјҲрҹ“қпјүпјҡиіҮж–ҷеӨҫйҲ•еңЁ Edit YAML е·ҰеҒҙпјҢй–Ӣи©ІзүҮ video\{ж—Ҙжңҹ жЁҷйЎҢ}\ -->
                <Grid Grid.Row="2" Margin="0,6,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Button x:Name="OpenFolderBtn" Grid.Column="0" Content="&#x1F4C1;" Width="32" Height="26" Margin="0,0,4,0"
                          ToolTip="Open this video's folder (its subtitle.yaml and any web transcript files)"/>
                  <Button x:Name="EditYamlBtn" Grid.Column="1" Content="&#x1F4DD; Edit YAML" Height="26"
                          IsEnabled="False" ToolTip="Edit the whole subtitle as one YAML file (manual override: fix line breaks / speakers)"/>
                </Grid>
              </Grid>

              <!-- еҸійҚөйҒёе–®ж–јзЁӢејҸз«ҜдҫқжёёжЁҷдёӢд№ӢеҲ—еӢ•ж…ӢеЎ«е…ҘпјҲCopy lineпјӢеҝ«йҖҹжҢҮе®ҡ/дҝ®жӯЈиӘӘи©ұдәәпјҢ#189пјүпјӣиҰӢ OnCueContextMenuOpening -->
              <ListBox x:Name="CueList" Grid.Row="2" Background="#55FFFFFF" BorderBrush="#F4C2D0" BorderThickness="1"
                       ScrollViewer.HorizontalScrollBarVisibility="Disabled" ToolTip="Double-click a line to jump there (paused); click a selected line to play/pause; right-click to copy or set the speaker">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <!-- жҷӮй–“жЁҷ(ж·Ў)пјӢиӘӘи©ұдәә(зІ—)пјӢеҸ°и©һгҖӮRun.Text з¶Ғе®ҡй җиЁӯ TwoWayпјҢе°Қе”Ҝи®Җеұ¬жҖ§жңғж“ІдҫӢеӨ– вҶ’ жҳҺжҢҮ OneWay -->
                    <TextBlock TextWrapping="Wrap" Margin="2" FontSize="12"><Run Text="{Binding TimeLabel, Mode=OneWay}" Foreground="#9A6A82" FontSize="11"/><Run Text="{Binding SpeakerLabel, Mode=OneWay}" FontWeight="Bold"/><Run Text="{Binding Text, Mode=OneWay}"/></TextBlock>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <Grid x:Name="YamlEditor" Grid.Row="2" Visibility="Collapsed">
                <Grid.RowDefinitions>
                  <RowDefinition Height="*"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBox x:Name="YamlBox" Grid.Row="0" AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap"
                         FontFamily="Consolas" FontSize="12" Background="#EEFFFFFF" Padding="6"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                  <Button x:Name="ApplyYamlBtn" Content="Apply" Width="76" Height="26" Margin="0,0,6,0"/>
                  <Button x:Name="CancelYamlBtn" Content="Cancel" Width="76" Height="26"/>
                </StackPanel>
              </Grid>
            </Grid>
            </Grid>
          </Grid>
        </Border>
      </Grid>
    </Grid>

    <!-- е…ұз”ЁзӢҖж…ӢеҲ—пјҲ#177пјүпјҡе…©еӯҗй ҒзҡҶеҸҜиҰӢпјӣијүе…Ҙ/йҢҜиӘӨиЁҠжҒҜдёҚеӣ еҲҮеҲ°е…§е®№й ҒиҖҢиў«йҒ® -->
    <TextBlock x:Name="StatusText" Grid.Row="2" Margin="4,6,4,0" FontSize="12" Foreground="#B0578D" TextWrapping="Wrap"
               Text="Paste a subtitle-file URL under Acquire, then Load a result."/>
  </Grid>
</UserControl>
