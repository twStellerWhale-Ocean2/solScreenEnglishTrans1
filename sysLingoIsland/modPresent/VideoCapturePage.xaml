<UserControl x:Class="LingoIsland.Present.VideoCapturePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="Transparent">
  <!-- зөұдёҖзүҲйқўпјҲ#167пјүпјҡе·ҰпјқеҪұзүҮжё…е–®пјҲClear allпјӢtheme зҜ©йҒёпјӣеҸійҚө/Delete еҲӘпјүпҪңеҸідёҠпјқзҚІеҸ–еҚҖеЎҠпјҲз¶ІеқҖијүе…ҘпјүпҪңеҸідёӢпјқе…§е®№еҚҖеЎҠпјҲж’ӯж”ҫеҷЁпјӢеӯ—е№•пјү -->
  <Grid Margin="10">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="200" MinWidth="150"/>
      <ColumnDefinition Width="6"/>
      <ColumnDefinition Width="*" MinWidth="300"/>
    </Grid.ColumnDefinitions>

    <!-- е·ҰпјҡVideosпјӢClear allпјҲзҪ®й ӮпјүпјӢдҫқ theme зҜ©йҒёпјӢжё…е–® -->
    <Grid Grid.Column="0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <Grid Grid.Row="0">
        <TextBlock Text="Videos" FontWeight="Bold" FontSize="13" Foreground="{StaticResource PinkText}" VerticalAlignment="Center"/>
        <Button x:Name="ClearVideosBtn" Content="Clear all" Style="{StaticResource GhostButton}" HorizontalAlignment="Right"/>
      </Grid>
      <!-- дҫқ theme зҜ©йҒёпјҲең–ж–ҮдёӢжӢүпјҢеӨҡеӘ’й«”дё»йЎҢз®ЎзҗҶВ·Bпјү -->
      <ComboBox x:Name="VideoThemeFilter" Grid.Row="1" Height="26" Margin="0,6,0,4"
                VerticalContentAlignment="Center" ToolTip="Filter videos by theme"/>
      <Border Grid.Row="2" Style="{StaticResource Card}">
        <Grid>
          <ListBox x:Name="VideoList" BorderThickness="0" Background="Transparent" Margin="4"
                   HorizontalContentAlignment="Stretch"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                   ToolTip="Click to load; right-click or press Delete to remove"/>
          <TextBlock x:Name="VideoEmptyHint" Text="No videos yet. Paste a YouTube link and Load."
                     Foreground="#9A6A82" FontSize="12" TextWrapping="Wrap" MaxWidth="160"
                     TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
      </Border>
    </Grid>

    <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="Transparent"/>

    <!-- еҸіпјҡдёҠпјқзҚІеҸ–еҚҖеЎҠпјҲз¶ІеқҖијёе…ҘпјӢLoadпјӢзӢҖж…ӢпјүпҪңдёӢпјқе…§е®№еҚҖеЎҠпјҲж’ӯж”ҫеҷЁпҪңйҖҗеҸҘеӯ—е№•пјү -->
    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Style="{StaticResource Card}" Padding="12">
        <StackPanel>
          <TextBlock Text="Load a video" FontWeight="Bold" FontSize="14" Foreground="{StaticResource PinkText}" Margin="0,0,0,8"/>

          <!-- в‘  й—ңйҚөеӯ— вҶ’ жҗңе°Ӣ вҶ’ йҒёж“Ү вҶ’ ијүе…ҘпјҲ#173пјҡжҳҺзўәеҲҶи·ҜдёҖпјү -->
          <TextBlock Text="&#x2460; Search YouTube by keywords" FontWeight="SemiBold" Foreground="#B0578D" Margin="0,0,0,4"/>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox" Grid.Column="0" Height="30" VerticalContentAlignment="Center" Padding="6,0"
                     Background="#66FFFFFF" ToolTip="Type keywords (prefilled from the active theme), then Search"/>
            <Button x:Name="SearchBtn" Grid.Column="1" Content="&#x1F50E; Search" Width="100" Height="30" Margin="8,0,0,0"/>
          </Grid>
          <ComboBox x:Name="SearchResults" Height="34" Margin="0,6,0,0" Visibility="Collapsed"
                    ToolTip="Pick a result to load it"/>

          <!-- еҲҶйҡ”пјҡе…©жўқдҫҶжәҗи·Ҝеҫ‘еҗ„иҮӘзҚЁз«Ӣ -->
          <Border Height="1" Background="#33B0578D" Margin="0,12,0,10"/>

          <!-- в‘Ў з¶ІеқҖ вҶ’ ијүе…ҘпјҲ#173пјҡжҳҺзўәеҲҶи·ҜдәҢпјү -->
          <TextBlock Text="&#x2461; Or paste a YouTube link" FontWeight="SemiBold" Foreground="#B0578D" Margin="0,0,0,4"/>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="UrlBox" Grid.Column="0" Height="30" VerticalContentAlignment="Center" Padding="6,0"
                     Background="#66FFFFFF" ToolTip="Paste a YouTube link or 11-character video ID, then Load"/>
            <Button x:Name="LoadBtn" Grid.Column="1" Content="Load" Width="90" Height="30" Margin="8,0,0,0"/>
          </Grid>

          <TextBlock x:Name="StatusText" Margin="2,10,2,0" FontSize="12" Foreground="#B0578D" TextWrapping="Wrap"
                     Text="Search by keywords and pick a result, or paste a link вҖ” then Load."/>
        </StackPanel>
      </Border>

      <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,8,0,0" Padding="8">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <!-- жүҖеұ¬дё»йЎҢпјҲе…§е®№еҚҖеЎҠдёҠж–№пјӣйЎҜзӨә/ж”№жҢҮжҙҫзӣ®еүҚеҪұзүҮд№Ӣдё»йЎҢпјҢ#173пјү -->
          <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="2,0,2,8" VerticalAlignment="Center">
            <TextBlock Text="Theme:" VerticalAlignment="Center" Foreground="{StaticResource PinkText}" Margin="0,0,6,0"/>
            <ComboBox x:Name="VideoThemePicker" MinWidth="180" Height="26" VerticalContentAlignment="Center"
                      IsEnabled="False" ToolTip="Show / change the theme this video belongs to"/>
          </StackPanel>

          <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" MinWidth="260"/>
              <ColumnDefinition Width="6"/>
              <ColumnDefinition Width="230" MinWidth="150"/>
            </Grid.ColumnDefinitions>

          <!-- дёӯпјҡж’ӯж”ҫеҷЁпјӢз•¶еүҚеҸҘеӯ—е№•её¶пјӢжҺ§еҲ¶ -->
          <Grid Grid.Column="0">
            <Grid.RowDefinitions>
              <RowDefinition Height="*" MinHeight="120"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="Black" CornerRadius="6" ClipToBounds="True">
              <wv2:WebView2 x:Name="Web"/>
            </Border>

            <Border Grid.Row="1" Background="#88FFFFFF" BorderBrush="#F4C2D0" BorderThickness="1" CornerRadius="6"
                    Margin="0,8,0,0" Padding="10" MinHeight="52">
              <!-- еӯ—зҙҡ/зІ—й«”з”ұ SubtitleDisplaySettings ж–ј ApplySubtitleDisplay() еҘ—з”ЁпјҲиЁӯе®ҡеҸҜиӘҝпјҢжҜ”з…§зӯҶиЁҳпјүпјӣж–Үеӯ—иүІжҜ”з…§зӯҶиЁҳжўқзӣ® #3A2C33 -->
              <TextBlock x:Name="SubtitleBand" TextWrapping="Wrap" Foreground="#3A2C33"/>
            </Border>

            <WrapPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
              <Button x:Name="ReplayBtn" Content="&#x23EE; Replay" Width="92" Height="28" Margin="0,0,6,4" IsEnabled="False"/>
              <Button x:Name="ResumeBtn" Content="&#x25B6; Continue" Width="96" Height="28" Margin="0,0,6,4" IsEnabled="False"/>
              <Button x:Name="NextBtn" Content="&#x23ED; Next" Width="84" Height="28" Margin="0,0,6,4" IsEnabled="False"/>
              <Button x:Name="AddNoteBtn" Content="&#xFF0B; Add to Notes" Width="132" Height="28" Margin="10,0,0,4" IsEnabled="False"/>
              <!-- жҢҮе®ҡиӘӘи©ұдәәжүҚжҡ«еҒңпјҲеўһйҮҸ7пјү -->
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,4">
                <TextBlock Text="Pause at:" VerticalAlignment="Center" Foreground="#B0578D" Margin="0,0,4,0"/>
                <ComboBox x:Name="PauseAtSpeaker" MinWidth="110" Height="26" VerticalContentAlignment="Center"
                          IsEnabled="False" ToolTip="Only pause at this speaker's lines (others play through)"/>
              </StackPanel>
            </WrapPanel>
          </Grid>

          <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="Transparent"/>

          <!-- еҸіпјҡиӘӘи©ұдәәзҜ©йҒёпјӢдҫҶжәҗз–ҠеҠ пјӢйҖҗеҸҘеӯ—е№•жё…е–®пјҲй»һи·іпјүпјҸж•ҙжӘ” YAML з·Ёдҝ® -->
          <Grid Grid.Column="2">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <ComboBox x:Name="SpeakerFilter" Grid.Row="0" Height="26" VerticalContentAlignment="Center"
                      IsEnabled="False" ToolTip="Filter lines by speaker"/>

            <Grid Grid.Row="1" Margin="0,4,0,4">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <!-- е…©йЎҶиӘӘи©ұдәәдҫҶжәҗпјҲеҗҢз–ҠеҠ жһ¶ж§ӢпјүпјҡAI дҫқеҸ°и©һжҺЁж–·пјҲеўһйҮҸ6пјүпҪңрҹҢҗ з¶ІжҗңдёҠз¶ІжүҫйҖҗеӯ—зЁҝпјҲеўһйҮҸ6bпјү -->
              <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="InferSpeakersBtn" Grid.Column="0" Content="AI speakers" Height="26" Margin="0,0,3,0"
                        IsEnabled="False" ToolTip="Infer likely speakers from the dialogue using AI (uses your OpenAI key; inference, not ground truth)"/>
                <Button x:Name="WebSpeakersBtn" Grid.Column="1" Content="&#x1F310; Web" Height="26" Margin="3,0,0,0"
                        IsEnabled="False" ToolTip="Search the web for this show's transcript to label speakers (OpenAI web search; uses your OpenAI key)"/>
              </Grid>
              <Button x:Name="EditYamlBtn" Grid.Row="1" Content="Edit YAML" Height="26" Margin="0,4,0,0"
                      IsEnabled="False" ToolTip="Edit the whole subtitle as one YAML file (fix line breaks / speakers)"/>
            </Grid>

            <ListBox x:Name="CueList" Grid.Row="2" Background="#55FFFFFF" BorderBrush="#F4C2D0" BorderThickness="1"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" ToolTip="Click a line to jump there">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <!-- иӘӘи©ұдәәеҗҚзЁұзІ—й«”гҖҒеҸ°и©һжӯЈеёёпјҲ#еӯ—е№•иӘӘи©ұдәәжЁҷзІ—й«”пјүгҖӮRun.Text з¶Ғе®ҡй җиЁӯ TwoWayпјҢе°Қе”Ҝи®Җеұ¬жҖ§жңғж“ІдҫӢеӨ– вҶ’ жҳҺжҢҮ OneWay -->
                  <TextBlock TextWrapping="Wrap" Margin="2" FontSize="12"><Run Text="{Binding SpeakerLabel, Mode=OneWay}" FontWeight="Bold"/><Run Text="{Binding Text, Mode=OneWay}"/></TextBlock>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <Grid x:Name="YamlEditor" Grid.Row="2" Visibility="Collapsed">
              <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <TextBox x:Name="YamlBox" Grid.Row="0" AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap"
                       FontFamily="Consolas" FontSize="12" Background="#EEFFFFFF" Padding="6"
                       VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"/>
              <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                <Button x:Name="ApplyYamlBtn" Content="Apply" Width="76" Height="26" Margin="0,0,6,0"/>
                <Button x:Name="CancelYamlBtn" Content="Cancel" Width="76" Height="26"/>
              </StackPanel>
            </Grid>
          </Grid>
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>
