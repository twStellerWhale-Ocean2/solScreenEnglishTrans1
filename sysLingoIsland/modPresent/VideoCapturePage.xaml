<UserControl x:Class="LingoIsland.Present.VideoCapturePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:local="clr-namespace:LingoIsland.Present"
             Background="Transparent">
  <UserControl.Resources>
    <!-- 標準表格控制項 DataGrid 主題（#177）：透明底、粉表頭、細列分隔、粉選取；欄可拖曳調寬/排序/重排（內建） -->
    <Style x:Key="GridColHeader" TargetType="DataGridColumnHeader">
      <Setter Property="Foreground" Value="#B0578D"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Background" Value="#22F4C2D0"/>
      <Setter Property="BorderBrush" Value="#33B0578D"/>
      <Setter Property="BorderThickness" Value="0,0,1,1"/>
      <Setter Property="Padding" Value="6,5"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style x:Key="GridRow" TargetType="DataGridRow">
      <Setter Property="Background" Value="Transparent"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#22B0578D"/></Trigger>
        <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="{StaticResource PinkTint}"/></Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="GridCell" TargetType="DataGridCell">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="Foreground" Value="#3A2C33"/>
      <Setter Property="Padding" Value="2,0"/>
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="Transparent"/>
          <Setter Property="Foreground" Value="#3A2C33"/>
        </Trigger>
      </Style.Triggers>
    </Style>
  </UserControl.Resources>
  <!-- 版面統一（#182）：兩子頁籤【獲得】（關鍵字搜尋＋結果表格＋網址載入）／【內容】（左影片清單｜右播放器＋逐句字幕）＋共用狀態列 -->
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- 子頁籤：內容 / 獲得（USR：先內容再獲得；可見性切換，非 TabControl，避免切頁卸載重建 WebView2 播放器、中斷播放） -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
      <RadioButton x:Name="SubTabPlay" Style="{StaticResource SubTab}" GroupName="VideoSubTab" IsChecked="True" Content="內容"/>
      <RadioButton x:Name="SubTabSearch" Style="{StaticResource SubTab}" GroupName="VideoSubTab" Content="獲得"/>
    </StackPanel>

    <!-- body：兩 pane 疊放同格，靠可見性切換 -->
    <Grid Grid.Row="1">

      <!-- 【獲得】關鍵字搜尋＋結果表格＋網址載入 -->
      <Border x:Name="SearchPane" Style="{StaticResource Card}" Padding="12" VerticalAlignment="Top" Visibility="Collapsed">
        <StackPanel>
          <TextBlock Text="Add a video" FontWeight="Bold" FontSize="14" Foreground="{StaticResource PinkText}" Margin="0,0,0,6"/>

          <!-- 單一輸入框（epic #178 增量6′「輸入 pivot」）：貼含**具體 YouTube 影片網址＋字幕檔網址**之自然語言文字。
               程式抽出兩網址（**不做關鍵字搜尋**——要求具體 URL、避免不穩的 AI 配片與鬼打牆），走載入管線建立字幕
               （取字幕檔→整理說話人＋台詞→Whisper 取時間→逐句對齊；跑前確認費用），加入內容頁。字幕檔須為含說話人之逐字稿頁。 -->
          <TextBlock TextWrapping="Wrap" Foreground="#9A6A82" FontSize="11.5" Margin="0,0,0,8"
                     Text="Paste text that has a YouTube video URL and its subtitle-file URL (a transcript page that names the speakers). LingoIsland reads both, builds speaker subtitles timed to the real audio, and adds the video to your Content tab. Uses your OpenAI key; confirms the cost first."/>
          <!-- 多行輸入框＋空框範例佔位（不搶輸入、有字即隱） -->
          <Grid>
            <TextBox x:Name="AcqInputBox" MinHeight="128" MaxHeight="240" AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top" Padding="8" FontSize="12.5"
                     Background="#66FFFFFF" ToolTip="Paste a YouTube video URL and a subtitle-file URL (both required), then press Enter or click Add video"/>
            <TextBlock x:Name="AcqPlaceholder" IsHitTestVisible="False" Foreground="#B692A6" FontSize="12"
                       Margin="11,9,10,10" VerticalAlignment="Top" TextWrapping="Wrap">
              <Run Text="Paste the video and subtitle links, for example:"/><LineBreak/>
              <Run Text="Pups and the Pirate Treasure"/><LineBreak/>
              <Run Text="影片：https://www.youtube.com/watch?v=hc4hH7JMV_g"/><LineBreak/>
              <Run Text="字幕：https://pawpatrol.fandom.com/wiki/Pups_and_the_Pirate_Treasure/Transcript"/>
            </TextBlock>
          </Grid>
          <Grid Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Foreground="#C89AB0" FontSize="10.5" VerticalAlignment="Center" TextWrapping="Wrap"
                       Text="Needs a real video URL and a real subtitle-file URL — no keyword search."/>
            <Button x:Name="AcqBuildBtn" Grid.Column="1" Content="&#x2699; Add video" Width="132" Height="32" VerticalAlignment="Center"/>
          </Grid>

        </StackPanel>
      </Border>

      <!-- 【內容】左＝影片清單（Clear all＋theme 篩選；右鍵/Delete 刪）｜右＝播放器＋逐句字幕（預設隱藏，載入影片時自動切換至此） -->
      <Grid x:Name="PlayPane">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="200" MinWidth="150"/>
          <ColumnDefinition Width="6"/>
          <ColumnDefinition Width="*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <!-- 左：Videos＋Clear all（置頂）＋依 theme 篩選＋清單 -->
        <Grid Grid.Column="0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Grid Grid.Row="0">
            <TextBlock Text="Videos" FontWeight="Bold" FontSize="13" Foreground="{StaticResource PinkText}" VerticalAlignment="Center"/>
            <Button x:Name="ClearVideosBtn" Content="Clear all" Style="{StaticResource GhostButton}" HorizontalAlignment="Right"/>
          </Grid>
          <!-- 依 theme 篩選（圖文下拉，多媒體主題管理·B） -->
          <ComboBox x:Name="VideoThemeFilter" Grid.Row="1" Height="26" Margin="0,6,0,4"
                    VerticalContentAlignment="Center" ToolTip="Filter videos by theme"/>
          <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
              <ListBox x:Name="VideoList" BorderThickness="0" Background="Transparent" Margin="4"
                       HorizontalContentAlignment="Stretch"
                       ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                       ToolTip="Click to load; right-click or press Delete to remove"/>
              <TextBlock x:Name="VideoEmptyHint" Text="No videos yet. Add one under the Acquire tab."
                         Foreground="#9A6A82" FontSize="12" TextWrapping="Wrap" MaxWidth="160"
                         TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
          </Border>
        </Grid>

        <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="Transparent"/>

        <!-- 右：內容區塊（所屬主題＋播放中網址＋播放器｜逐句字幕） -->
        <Border Grid.Column="2" Style="{StaticResource Card}" Padding="8">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 所屬主題（內容區塊上方；顯示/改指派目前影片之主題，#173）＋播放中影片超連結網址（#177） -->
            <StackPanel Grid.Row="0" Margin="2,0,2,8">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Theme:" VerticalAlignment="Center" Foreground="{StaticResource PinkText}" Margin="0,0,6,0"/>
                <ComboBox x:Name="VideoThemePicker" MinWidth="180" Height="26" VerticalContentAlignment="Center"
                          IsEnabled="False" ToolTip="Show / change the theme this video belongs to"/>
              </StackPanel>
              <!-- 影片標題（#187；#189 改唯讀 TextBox 使可選取／複製）：置於網址之上；載入即顯（先用清單標題，起播後以播放器實名更新） -->
              <TextBox x:Name="VideoTitleText" Margin="0,6,0,0" FontWeight="SemiBold" FontSize="13.5"
                       Foreground="{StaticResource PinkText}" TextWrapping="Wrap" Visibility="Collapsed"
                       IsReadOnly="True" IsReadOnlyCaretVisible="False" BorderThickness="0" Background="Transparent"
                       Padding="0" Cursor="IBeam" ToolTip="影片標題（可選取／複製）"/>
              <!-- 播放中影片之超連結網址（#177）：可點開 YouTube 原頁；無載入時隱藏 -->
              <TextBlock x:Name="WatchUrlRow" Margin="0,3,0,0" FontSize="11.5" Foreground="#9A6A82"
                         Visibility="Collapsed" TextTrimming="CharacterEllipsis">
                <Run Text="URL: "/><Hyperlink x:Name="WatchUrlLink" RequestNavigate="OnOpenExternalLink"
                         Foreground="{StaticResource PinkText}"><Run x:Name="WatchUrlText"/></Hyperlink>
              </TextBlock>
            </StackPanel>

            <Grid Grid.Row="1">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="260"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="230" MinWidth="150"/>
              </Grid.ColumnDefinitions>

            <!-- 中：播放器＋當前句字幕帶＋控制 -->
            <Grid Grid.Column="0">
              <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="120"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>

              <Border Grid.Row="0" Background="Black" CornerRadius="6" ClipToBounds="True">
                <Grid>
                  <wv2:WebView2 x:Name="Web"/>
                  <!-- 載入等待動畫（#186）：載入中收起 WebView2（避 airspace 遮住）、於黑底顯旋轉沙漏 -->
                  <StackPanel x:Name="LoadOverlay" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <local:Spinner Width="48" Height="48" Foreground="White"/>
                    <TextBlock Text="Loading…" Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0" FontSize="13"/>
                  </StackPanel>
                </Grid>
              </Border>

              <Border Grid.Row="1" Background="#88FFFFFF" BorderBrush="#F4C2D0" BorderThickness="1" CornerRadius="6"
                      Margin="0,8,0,0" Padding="10" MinHeight="52">
                <!-- 字級/粗體由 SubtitleDisplaySettings 於 ApplySubtitleDisplay() 套用（設定可調，比照筆記）；文字色比照筆記條目 #3A2C33。點字查詞；右鍵複製整句（#189，字可點故以右鍵複製取代拖選） -->
                <TextBlock x:Name="SubtitleBand" TextWrapping="Wrap" Foreground="#3A2C33">
                  <TextBlock.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="Copy line" Click="OnCopySubtitleLine"/>
                    </ContextMenu>
                  </TextBlock.ContextMenu>
                </TextBlock>
              </Border>

              <WrapPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                <Button x:Name="ReplayBtn" Content="&#x23EE; Previous" Width="96" Height="28" Margin="0,0,6,4" IsEnabled="False"/>
                <Button x:Name="ResumeBtn" Content="&#x25B6; Continue" Width="96" Height="28" Margin="0,0,6,4" IsEnabled="False"/>
                <Button x:Name="NextBtn" Content="&#x23ED; Next" Width="84" Height="28" Margin="0,0,6,4" IsEnabled="False"/>
                <Button x:Name="AddNoteBtn" Width="132" Height="28" Margin="10,0,0,4" IsEnabled="False">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE70B;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="Add to Notes" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <!-- 指定說話人才暫停（增量7） -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,4">
                  <TextBlock Text="Pause:" VerticalAlignment="Center" Foreground="#B0578D" Margin="0,0,4,0"/>
                  <!-- 兩模式（#189-checklist USR）：不等待／依「說話人勾選面板」勾選者等待。對象＝字幕清單下方勾選清單。 -->
                  <ComboBox x:Name="PauseAtSpeaker" MinWidth="140" Height="26" VerticalContentAlignment="Center"
                            IsEnabled="False" ToolTip="Pause at the speakers checked in the Speakers list (below the subtitle list), or never.">
                    <ComboBoxItem>Don't pause</ComboBoxItem>
                    <ComboBoxItem>Pause at selected</ComboBoxItem>
                  </ComboBox>
                </StackPanel>
              </WrapPanel>
            </Grid>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- 右：說話人篩選＋來源疊加＋逐句字幕清單（點跳）／整檔 YAML 編修 -->
            <Grid Grid.Column="2">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>

              <!-- 顯示模式（#189-checklist USR 修）：全部顯示／只顯示勾選者／只加粗勾選者。說話人字型顏色為常設（依主題描述含其名，見程式），與此三模式無關。 -->
              <ComboBox x:Name="SpeakerFilter" Grid.Row="1" Height="26" VerticalContentAlignment="Center" Margin="0,2,0,4"
                        IsEnabled="False" ToolTip="How to show the checked speakers below: show all lines, show only theirs, or keep all lines but bold theirs. (Speaker text colour is always on, from the theme.)">
                <ComboBoxItem>Show all</ComboBoxItem>
                <ComboBoxItem>Show selected only</ComboBoxItem>
                <ComboBoxItem>Bold selected only</ComboBoxItem>
              </ComboBox>

              <Grid Grid.Row="0" Margin="0,0,0,2">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- 時間偏移（epic #178 增量6′-B「時間 pivot」）：整份字幕時間整體平移校正——取代原 🎙 Voice（Whisper 已移除）。
                     字幕快→輸負（如 -00:05 使字幕延後對上發音）、慢→輸正；Enter 或按 Shift 套用、存回。來源說明已取消（反正都是字幕）。 -->
                <Grid Grid.Row="0" Margin="0,2,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="26"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="&#x23F1;" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"
                             ToolTip="Shift all subtitle times (＋ = later, − = earlier)."/>
                  <TextBox x:Name="OffsetBox" Grid.Column="1" Height="26" VerticalContentAlignment="Center" Padding="6,0" Text="00:00"
                           IsEnabled="False" ToolTip="Time offset MM:SS (or seconds), signed. Positive = subtitles appear later, negative = earlier. Press Enter or Shift to apply to every line."/>
                  <!-- 即時 ∓1 秒微調（USR：Shift 左側增減鈕）：邊看邊對嘴，不必打字 -->
                  <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="4,0,0,0">
                    <Button x:Name="OffsetMinusBtn" Content="&#x2212;" Width="26" Height="26" FontSize="14" IsEnabled="False"
                            ToolTip="Nudge all subtitles 1s earlier (applied &amp; saved)."/>
                    <Button x:Name="OffsetPlusBtn" Content="&#xFF0B;" Width="26" Height="26" FontSize="12" Margin="3,0,0,0" IsEnabled="False"
                            ToolTip="Nudge all subtitles 1s later (applied &amp; saved)."/>
                  </StackPanel>
                  <Button x:Name="OffsetApplyBtn" Grid.Column="3" Content="Shift" Width="54" Height="26" Margin="6,0,0,0"
                          IsEnabled="False" ToolTip="Shift every subtitle line by the offset (saved)."/>
                </Grid>
                <!-- 開啟本片資料夾（#189，📁）＋整檔 YAML 編修（📝）：資料夾鈕在 Edit YAML 左側，開該片 video\{日期 標題}\ -->
                <Grid Grid.Row="1" Margin="0,6,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Button x:Name="OpenFolderBtn" Grid.Column="0" Content="&#x1F4C1;" Width="32" Height="26" Margin="0,0,4,0"
                          ToolTip="Open this video's folder (its subtitle.yaml and any web transcript files)"/>
                  <Button x:Name="EditYamlBtn" Grid.Column="1" Content="&#x1F4DD; Edit YAML" Height="26"
                          IsEnabled="False" ToolTip="Edit the whole subtitle as one YAML file (manual override: fix line breaks / speakers)"/>
                </Grid>
              </Grid>

              <!-- 字幕清單（上）＋可上下拖拉之說話人勾選面板（下），中間 GridSplitter（#189-checklist USR） -->
              <Grid x:Name="CuePanel" Grid.Row="2">
                <Grid.RowDefinitions>
                  <RowDefinition Height="*" MinHeight="120"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="150" MinHeight="46"/>
                </Grid.RowDefinitions>

                <!-- 右鍵選單於程式端依游標下之列動態填入（Copy line＋快速指定/修正說話人，#189）；見 OnCueContextMenuOpening -->
                <ListBox x:Name="CueList" Grid.Row="0" Background="#55FFFFFF" BorderBrush="#F4C2D0" BorderThickness="1"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" ToolTip="Double-click a line to jump there (paused); click a selected line to play/pause; right-click to copy or set the speaker">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <!-- 時間標(淡)＋說話人(粗)＋台詞。Run.Text 綁定預設 TwoWay，對唯讀屬性會擲例外 → 明指 OneWay。
                           SpeakerBrush＝字型顏色（常設，依說話人＝主題描述配對之鮮明色）；LineWeight＝只加粗勾選模式下勾選者加粗（#189-checklist USR）。 -->
                      <TextBlock TextWrapping="Wrap" Margin="2" FontSize="12"><Run Text="{Binding TimeLabel, Mode=OneWay}" Foreground="#9A6A82" FontSize="11"/><Run Text="{Binding SpeakerLabel, Mode=OneWay}" FontWeight="Bold" Foreground="{Binding SpeakerBrush}"/><Run Text="{Binding Text, Mode=OneWay}" FontWeight="{Binding LineWeight}" Foreground="{Binding SpeakerBrush}"/></TextBlock>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <GridSplitter Grid.Row="1" Height="10" Margin="0,2" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                              ResizeDirection="Rows" ResizeBehavior="PreviousAndNext" Background="#E8A9BE"
                              ToolTip="Drag to resize the speaker list"/>

                <!-- 說話人勾選面板（Everyone＋各原子說話人；合唸句拆開去重）：字幕篩選/顯示與影片等待共用同一份勾選（#189-checklist USR） -->
                <Border Grid.Row="2" Background="#55FFFFFF" BorderBrush="#F4C2D0" BorderThickness="1" CornerRadius="4">
                  <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Speakers — used by the filter &amp; pause above" Foreground="#B0578D"
                               FontSize="11" Margin="6,3,6,2" TextTrimming="CharacterEllipsis"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="4,0,4,4">
                      <ItemsControl x:Name="SpeakerChecks">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <!-- 斑馬紋列底色（RowStripe，USR：全白難辨列尾圖示對應哪名字）＋勾選（左撐滿）＋「加入筆記」鈕（右，去灰框、粉色圖示，同 Notes 分頁 glyph）。全選列不顯此鈕。 -->
                            <Grid Background="{Binding RowStripe}">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                              </Grid.ColumnDefinitions>
                              <CheckBox Grid.Column="0" Content="{Binding Name}" IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                        FontWeight="{Binding Weight}" FontSize="12" Margin="4,2" VerticalContentAlignment="Center"/>
                              <Button Grid.Column="1" Content="&#xE70B;" FontFamily="Segoe MDL2 Assets" Foreground="#B0578D"
                                      Background="Transparent" BorderThickness="0" Cursor="Hand"
                                      Width="24" Height="22" Padding="0" FontSize="15" Margin="2,1,6,1"
                                      Visibility="{Binding AddNotesVisibility}" Click="OnAddSpeakerNotesClick"
                                      ToolTip="Add all of this speaker's lines to My Notes (confirms cost; translates each)"/>
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </DockPanel>
                </Border>
              </Grid>

              <Grid x:Name="YamlEditor" Grid.Row="2" Visibility="Collapsed">
                <Grid.RowDefinitions>
                  <RowDefinition Height="*"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBox x:Name="YamlBox" Grid.Row="0" AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap"
                         FontFamily="Consolas" FontSize="12" Background="#EEFFFFFF" Padding="6"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                  <Button x:Name="ApplyYamlBtn" Content="Apply" Width="76" Height="26" Margin="0,0,6,0"/>
                  <Button x:Name="CancelYamlBtn" Content="Cancel" Width="76" Height="26"/>
                </StackPanel>
              </Grid>
            </Grid>
            </Grid>
          </Grid>
        </Border>
      </Grid>
    </Grid>

    <!-- 共用狀態列（#177）：兩子頁皆可見；載入/錯誤訊息不因切到內容頁而被遮 -->
    <TextBlock x:Name="StatusText" Grid.Row="2" Margin="4,6,4,0" FontSize="12" Foreground="#B0578D" TextWrapping="Wrap"
               Text="Add a video under the Acquire tab: paste its video URL and its subtitle-file URL."/>
  </Grid>
</UserControl>
