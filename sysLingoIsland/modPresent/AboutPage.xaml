<UserControl x:Class="LingoIsland.Present.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Issue #79：資訊卡 + 更新紀錄（ChangeLog）；#97 UI：About 卡改橫向（左 logo、右資訊），Change Log 於其下整條寬 -->
  <Grid Margin="16">
    <!-- About 卡：女孩圖在左、資訊在右（#159：更新紀錄改「Change Log」按鈕跳出獨立視窗、不再常駐佔頁） -->
    <Border VerticalAlignment="Top" Style="{StaticResource Card}" Padding="20">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Image Grid.Column="0" Source="pack://application:,,,/assets/icon.png"
               Width="96" Height="96" VerticalAlignment="Center" Margin="4,0,22,0"/>

        <StackPanel Grid.Column="1" VerticalAlignment="Center">
          <TextBlock Text="LingoIsland" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
          <TextBlock x:Name="VersionText" FontSize="13" Foreground="{StaticResource PinkSub}" Margin="0,3,0,8"/>
          <TextBlock Text="遊戲畫面即時英文查詢" FontSize="12.5"
                     Foreground="{StaticResource PinkSub}" TextWrapping="Wrap"/>
          <TextBlock Text="© 2026 Carlton Chen．保留一切權利。" FontSize="12.5"
                     Foreground="{StaticResource PinkSub}" Margin="0,8,0,2"/>
          <TextBlock Text="聯絡：carlton0521@gmail.com" FontSize="12.5" Foreground="{StaticResource PinkSub}"/>
          <TextBlock FontSize="12.5" Margin="0,2,0,0">
            <Hyperlink x:Name="GitHubLink" NavigateUri="https://github.com/twStellerWhale-Ocean2/solLingoIsland"
                       RequestNavigate="OnOpenLink" Foreground="{StaticResource PinkText}">GitHub</Hyperlink>
          </TextBlock>
          <TextBlock Text="辨識與翻譯由 OpenAI 提供；朗讀採 Windows 內建語音。" FontSize="11.5"
                     Foreground="#9A6A82" Margin="0,10,0,0" TextWrapping="Wrap"/>
          <!-- 更新區（Issue #51）：僅 Velopack 安裝形態顯示；dev 裸跑隱藏 -->
          <StackPanel x:Name="UpdatePanel" Orientation="Horizontal" Margin="0,12,0,0" Visibility="Collapsed">
            <TextBlock x:Name="UpdateStatusText" FontSize="12.5" Foreground="{StaticResource PinkSub}"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Button x:Name="CheckUpdateBtn" Content="檢查更新" Style="{StaticResource GhostButton}"/>
            <Button x:Name="RestartUpdateBtn" Content="重啟以更新" Style="{StaticResource PinkButton}"
                    Visibility="Collapsed"/>
          </StackPanel>
          <!-- #159：更新紀錄改按鈕跳出獨立視窗；#199：移至「檢查更新」之後（更新區下方）——仍置於 UpdatePanel 之外、恆顯，不隨更新區於 dev 裸跑隱藏 -->
          <Button x:Name="ChangeLogBtn" Content="更新紀錄" Style="{StaticResource GhostButton}"
                  HorizontalAlignment="Left" Margin="0,12,0,0" ToolTip="檢視各版本的變更"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</UserControl>
