<UserControl x:Class="ScreenTrans.Present.OptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True" FontSize="14">
  <!-- 區塊序依使用頻率與關聯（Issue #40）：①喚起快捷鍵 ②AI 辨識翻譯（金鑰＋模型）③朗讀語音（含測試發音） -->
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="18,14,18,14">

      <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="Hotkeys" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>

          <TextBlock Text="Hotkey — freezes the screen, then drag to select or double-click a line"
                     FontSize="12" Foreground="{StaticResource PinkSub}" Margin="0,6,0,0" TextWrapping="Wrap"/>
          <StackPanel Orientation="Horizontal" Margin="0,2,0,4" VerticalAlignment="Center">
            <TextBlock x:Name="HotkeyStatus" MinWidth="150" VerticalAlignment="Center"
                       Foreground="{StaticResource PinkText}" FontWeight="SemiBold"/>
            <Button x:Name="ChangeHotkeyBtn" Content="Change" Style="{StaticResource GhostButton}" Margin="10,0,0,0"/>
          </StackPanel>

          <TextBlock x:Name="HotkeyHint"
                     Text="After clicking “Change”, press the key combination or mouse button you want (middle / side / both buttons); Esc to cancel."
                     FontSize="12" Foreground="#9A6A82" TextWrapping="Wrap" Margin="0,2,0,0"/>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="AI Recognition &amp; Translation (OpenAI)" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
          <TextBlock Text="API Key (OPENAI_API_KEY)" FontSize="12.5" Foreground="{StaticResource PinkSub}" Margin="0,6,0,0"/>
          <TextBlock x:Name="KeyStatus" Margin="0,2,0,4" Foreground="{StaticResource PinkSub}"/>
          <PasswordBox x:Name="KeyBox" Padding="6"/>
          <TextBlock Text="Paste to update; leave blank to keep unchanged. Saved to your user environment variable, never written to the app or config files."
                     FontSize="12" Foreground="#9A6A82" TextWrapping="Wrap" Margin="0,3,0,0"/>
          <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
            <TextBlock Text="Query model (vision)" FontSize="12.5" Foreground="{StaticResource PinkSub}"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="QueryModelBox" Padding="6,4" MinWidth="200"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="Speech voice (Windows built-in)" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
          <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
            <ComboBox x:Name="VoiceBox" MinWidth="260"/>
            <Button x:Name="TestBtn" Content="Test Voice" Style="{StaticResource GhostButton}" Margin="10,0,0,0"/>
          </StackPanel>
          <TextBlock Text="Uses Windows voices installed on your system; works offline, no quota."
                     FontSize="12" Foreground="#9A6A82" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="Pronunciation practice" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
          <TextBlock Text="In My Notes, hold the mic on a card to record and release to score; the score box turns green when your best score reaches the pass threshold."
                     FontSize="12" Foreground="{StaticResource PinkSub}" Margin="0,6,0,0" TextWrapping="Wrap"/>
          <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
            <TextBlock Text="Pass threshold" FontSize="12.5" Foreground="{StaticResource PinkSub}"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <Slider x:Name="PronThresholdSlider" Minimum="0" Maximum="100" Width="200"
                    IsSnapToTickEnabled="False" VerticalAlignment="Center"/>
            <TextBox x:Name="PronThresholdBox" Width="46" Margin="10,0,4,0" Padding="4,2"
                     TextAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Text="/ 100" FontSize="12" Foreground="{StaticResource PinkSub}" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
            <TextBlock Text="Scoring model (audio)" FontSize="12.5" Foreground="{StaticResource PinkSub}"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="PronModelBox" Padding="6,4" MinWidth="200"/>
          </StackPanel>
          <TextBlock Text="Uses your OpenAI key with an audio-capable model; the recording is sent to OpenAI for scoring and is not stored."
                     FontSize="12" Foreground="#9A6A82" TextWrapping="Wrap" Margin="0,3,0,0"/>
        </StackPanel>
      </Border>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
        <Button x:Name="SaveBtn" Content="Save" Style="{StaticResource PinkButton}"/>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
