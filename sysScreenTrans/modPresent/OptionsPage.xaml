<UserControl x:Class="ScreenTrans.Present.OptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True" FontSize="14">
  <!-- 區塊序依使用頻率與關聯（Issue #40）：①喚起快捷鍵 ②AI 辨識翻譯（金鑰＋模型）③朗讀語音（含測試發音） -->
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="18,14,18,14">

      <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="喚起快捷鍵" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
          <StackPanel Orientation="Horizontal" Margin="0,4,0,4" VerticalAlignment="Center">
            <TextBlock x:Name="HotkeyStatus" MinWidth="150" VerticalAlignment="Center"
                       Foreground="{StaticResource PinkText}" FontWeight="SemiBold"/>
            <Button x:Name="ChangeHotkeyBtn" Content="變更" Style="{StaticResource GhostButton}" Margin="10,0,0,0"/>
          </StackPanel>
          <TextBlock x:Name="HotkeyHint"
                     Text="按「變更」後直接按下想用的鍵盤組合或滑鼠鍵（中鍵／側鍵／左右同按）；Esc 取消。"
                     FontSize="12" Foreground="#9A6A82" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="AI 辨識翻譯（OpenAI）" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
          <TextBlock Text="API 金鑰（OPENAI_API_KEY）" FontSize="12.5" Foreground="{StaticResource PinkSub}" Margin="0,6,0,0"/>
          <TextBlock x:Name="KeyStatus" Margin="0,2,0,4" Foreground="{StaticResource PinkSub}"/>
          <PasswordBox x:Name="KeyBox" Padding="6"/>
          <TextBlock Text="貼上以更新；留空則不變更。存入使用者環境變數，不寫進程式或設定檔。"
                     FontSize="12" Foreground="#9A6A82" TextWrapping="Wrap" Margin="0,3,0,0"/>
          <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
            <TextBlock Text="查詢模型（vision）" FontSize="12.5" Foreground="{StaticResource PinkSub}"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="QueryModelBox" Padding="6,4" MinWidth="200"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="朗讀語音（Windows 內建）" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
          <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
            <ComboBox x:Name="VoiceBox" MinWidth="260"/>
            <Button x:Name="TestBtn" Content="測試發音" Style="{StaticResource GhostButton}" Margin="10,0,0,0"/>
          </StackPanel>
          <TextBlock Text="使用系統已安裝的 Windows 語音，離線可用、免額度。"
                     FontSize="12" Foreground="#9A6A82" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="智能配色規則（筆記底色）" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
          <TextBox x:Name="ColorRulesBox" Padding="6" Margin="0,6,0,3" MinHeight="60" MaxHeight="120"
                   TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
          <TextBlock Text="以自然語言描述哪類台詞用什麼底色（例：戰士角色台詞用粉紅、法師用粉藍）。留空＝不啟用。查詢時附加於提示，AI 回結果時順帶建議底色，於查詢結果頁自動預選（仍可臨時改）。"
                     FontSize="12" Foreground="#9A6A82" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
        <Button x:Name="SaveBtn" Content="儲存" Style="{StaticResource PinkButton}"/>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
