<Window x:Class="ScreenTrans.Present.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="查詢歷史" Width="640" Height="480" MinWidth="480" MinHeight="320"
        ShowInTaskbar="True" WindowStartupLocation="CenterScreen" Background="#F3F3F3"
        Icon="pack://application:,,,/assets/app.ico">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="44"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- 標題列＋清除全部 -->
    <Grid Grid.Row="0" Background="#FAFAFA">
      <TextBlock Text="查詢歷史" FontSize="15" FontWeight="SemiBold" Foreground="#1B1B1B"
                 VerticalAlignment="Center" Margin="16,0"/>
      <Button x:Name="ClearAllBtn" Content="清除全部" HorizontalAlignment="Right" VerticalAlignment="Center"
              Margin="0,0,16,0" Padding="12,5" Foreground="#8A2B2B" Background="White"
              BorderBrush="#C9C9C9" BorderThickness="1" Cursor="Hand"/>
      <Border Height="1" Background="#E2E2E2" VerticalAlignment="Bottom"/>
    </Grid>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="190"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- 左：日期分組 -->
      <Border Grid.Column="0" Background="#ECECEC" BorderBrush="#DCDCDC" BorderThickness="0,0,1,0">
        <ListBox x:Name="DateList" BorderThickness="0" Background="Transparent" Margin="6"
                 HorizontalContentAlignment="Stretch"/>
      </Border>

      <!-- 右：該日條目（新在上、最舊在下） -->
      <Grid Grid.Column="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10">
          <StackPanel x:Name="EntryPanel"/>
        </ScrollViewer>
        <TextBlock x:Name="EmptyHint" Text="尚無查詢紀錄。查詢後會自動出現在這裡。"
                   Foreground="#9A9A9A" FontSize="14"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
      </Grid>
    </Grid>
  </Grid>
</Window>
