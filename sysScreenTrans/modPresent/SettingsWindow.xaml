<Window x:Class="ScreenTrans.Present.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenTrans 設定" Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#FFF5F8" FontSize="14"
        Icon="pack://application:,,,/assets/icon.png">
  <StackPanel Margin="22,18,22,18">
    <TextBlock Text="ScreenTrans 設定" FontSize="20" FontWeight="SemiBold" Foreground="#B0688A" Margin="0,0,0,14"/>

    <TextBlock Text="OpenAI API 金鑰（OPENAI_API_KEY）" FontWeight="SemiBold" Foreground="#6D3A4D"/>
    <TextBlock x:Name="KeyStatus" Margin="0,2,0,4" Foreground="#8A5A6D"/>
    <PasswordBox x:Name="KeyBox" Padding="6"/>
    <TextBlock Text="貼上以更新；留空則不變更。存入使用者環境變數，不寫進程式或設定檔。"
               FontSize="12" Foreground="#9A6A82" TextWrapping="Wrap" Margin="0,3,0,14"/>

    <TextBlock Text="朗讀語音（Windows 內建）" FontWeight="SemiBold" Foreground="#6D3A4D"/>
    <ComboBox x:Name="VoiceBox" Margin="0,2,0,4"/>
    <TextBlock Text="使用系統已安裝的 Windows 語音，離線可用、免額度。清單為空時，請至「設定 → 時間與語言 → 語音」安裝語音包。"
               FontSize="12" Foreground="#9A6A82" TextWrapping="Wrap" Margin="0,0,0,10"/>

    <TextBlock Text="查詢模型（vision）" FontWeight="SemiBold" Foreground="#6D3A4D"/>
    <TextBox x:Name="QueryModelBox" Padding="6" Margin="0,2,0,16"/>

    <TextBlock Text="喚起快捷鍵" FontWeight="SemiBold" Foreground="#6D3A4D"/>
    <StackPanel Orientation="Horizontal" Margin="0,2,0,4" VerticalAlignment="Center">
      <TextBlock x:Name="HotkeyStatus" MinWidth="150" VerticalAlignment="Center"
                 Foreground="#6D3A4D" FontWeight="SemiBold"/>
      <Button x:Name="ChangeHotkeyBtn" Content="變更" Padding="12,4" Margin="10,0,0,0"/>
    </StackPanel>
    <TextBlock x:Name="HotkeyHint"
               Text="按「變更」後直接按下想用的鍵盤組合或滑鼠鍵（中鍵／側鍵／左右同按）；Esc 取消。"
               FontSize="12" Foreground="#9A6A82" TextWrapping="Wrap" Margin="0,0,0,16"/>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
      <Button x:Name="TestBtn" Content="測試發音" Padding="12,6" Margin="0,0,8,0"/>
      <Button x:Name="SaveBtn" Content="儲存" Padding="18,6" Margin="0,0,8,0"
              Background="#F4C2D0" Foreground="#6D3A4D" BorderThickness="0"/>
      <Button x:Name="CancelBtn" Content="取消" Padding="12,6"/>
    </StackPanel>
  </StackPanel>
</Window>
