<UserControl x:Class="ScreenTrans.Present.ContextPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="224"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- 左：命名情境清單 -->
    <Grid Grid.Column="0" Margin="10,8,4,10">
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Border Grid.Row="0" Style="{StaticResource Card}">
        <ListBox x:Name="List" BorderThickness="0" Background="Transparent" Margin="4"
                 HorizontalContentAlignment="Stretch"/>
      </Border>
      <Button Grid.Row="1" x:Name="AddBtn" Content="＋ 新增情境" Style="{StaticResource PinkButton}" Margin="0,6,0,0"/>
    </Grid>

    <!-- 右：編輯區 -->
    <Grid Grid.Column="1" Margin="6,8,10,10">
      <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,0,4,0">
        <StackPanel x:Name="Editor">
          <TextBlock Text="名稱" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
          <TextBox x:Name="NameBox" Padding="6" Margin="0,4,0,10"/>

          <TextBlock Text="情境描述（查詢時作為參考注入）" FontWeight="SemiBold" Foreground="{StaticResource PinkText}"/>
          <TextBox x:Name="DescBox" Padding="6" Margin="0,4,0,6" TextWrapping="Wrap"
                   AcceptsReturn="True" MinHeight="80" MaxHeight="150" VerticalScrollBarVisibility="Auto"/>

          <Border Style="{StaticResource Card}" Padding="8" Margin="0,0,0,8">
            <StackPanel>
              <Image x:Name="Preview" MaxHeight="150" HorizontalAlignment="Left" Stretch="Uniform" Margin="0,0,0,6"/>
              <TextBlock x:Name="NoImageHint" Text="（尚無圖片）" Foreground="#9A6A82" FontSize="12"/>
              <WrapPanel Margin="0,6,0,0">
                <Button x:Name="PasteBtn" Content="貼上剪貼簿圖片" Style="{StaticResource GhostButton}" Margin="0,0,6,6"/>
                <Button x:Name="UploadBtn" Content="上傳檔案" Style="{StaticResource GhostButton}" Margin="0,0,6,6"/>
                <Button x:Name="DescribeBtn" Content="🔎 以圖片自動解釋" Style="{StaticResource PinkButton}" Margin="0,0,6,6"/>
              </WrapPanel>
            </StackPanel>
          </Border>

          <TextBlock x:Name="StatusLine" Foreground="#2E7D46" FontSize="12" Margin="0,0,0,8"/>

          <WrapPanel>
            <Button x:Name="ActiveBtn" Content="設為使用中" Style="{StaticResource PinkButton}" Margin="0,0,8,6"/>
            <Button x:Name="SaveBtn" Content="儲存" Style="{StaticResource GhostButton}" Margin="0,0,8,6"/>
            <Button x:Name="DeleteBtn" Content="刪除" Foreground="#B23B3B" Style="{StaticResource GhostButton}" Margin="0,0,0,6"/>
          </WrapPanel>
        </StackPanel>
      </ScrollViewer>
      <TextBlock x:Name="EmptyHint" Text="尚無情境。按「＋ 新增情境」建立；可輸入文字，或貼上／上傳遊戲畫面由 AI 自動解釋。"
                 Foreground="#9A6A82" FontSize="13" TextWrapping="Wrap" MaxWidth="320"
                 TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
    </Grid>
  </Grid>
</UserControl>
