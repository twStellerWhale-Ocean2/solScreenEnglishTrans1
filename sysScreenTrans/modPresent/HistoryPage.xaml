<UserControl x:Class="ScreenTrans.Present.HistoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- 左日期欄頂端對齊（上不留空）；「清除全部」僅佔右欄頂（Issue #40） -->
  <Grid>
    <!-- 左側日期欄寬可拖拉調整（Issue #58） -->
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="180" MinWidth="130"/>
      <ColumnDefinition Width="Auto"/>
      <ColumnDefinition Width="*" MinWidth="240"/>
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Style="{StaticResource Card}" Margin="10,8,4,10">
      <ListBox x:Name="DateList" BorderThickness="0" Background="Transparent"
               Margin="4" HorizontalContentAlignment="Stretch"/>
    </Border>

    <GridSplitter Grid.Column="1" Style="{StaticResource ColSplitter}"/>

    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <Button x:Name="ClearAllBtn" Grid.Row="0" Content="清除全部" HorizontalAlignment="Right"
              Foreground="#8A2B2B" Style="{StaticResource GhostButton}" Margin="8,8,10,4"/>

      <Grid Grid.Row="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,0,10,10">
          <StackPanel x:Name="EntryPanel"/>
        </ScrollViewer>
        <TextBlock x:Name="EmptyHint" Text="尚無查詢紀錄。查詢後會自動出現在這裡。"
                   Foreground="#9A6A82" FontSize="13"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
