<UserControl x:Class="ScreenTrans.Present.NotesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <UserControl.Resources>
    <!-- 卡片行尾圓形圖示鈕（spec#10）：播音／麥克風同款圓鈕，明示可按；顏色由實體 Background/BorderBrush/Foreground 指定。 -->
    <Style x:Key="RoundIcon" TargetType="Button">
      <Setter Property="Width" Value="27"/>
      <Setter Property="Height" Value="27"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bg" CornerRadius="13.5"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bg" Property="Opacity" Value="0.82"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>
  <Grid>
    <!-- 左側欄寬可拖拉調整（Issue #58）：GridSplitter 於中間 Auto 欄 -->
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="212" MinWidth="150"/>
      <ColumnDefinition Width="Auto"/>
      <ColumnDefinition Width="*" MinWidth="240"/>
    </Grid.ColumnDefinitions>

    <!-- 左：頂部工具列（僅建立資料夾）＋標準多層資料夾樹（右鍵選單／F2 原地更名，Issue #38） -->
    <Grid Grid.Column="0" Margin="10,8,4,10">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <Button x:Name="NewFolderBtn" Grid.Row="0" Content="＋ New Folder" Style="{StaticResource GhostButton}"
              HorizontalAlignment="Left" Padding="10,4" Margin="0,0,0,6"/>
      <Border Grid.Row="1" Style="{StaticResource Card}">
        <TreeView x:Name="FolderTree" BorderThickness="0" Background="Transparent" AllowDrop="True" Margin="2"/>
      </Border>
    </Grid>

    <GridSplitter Grid.Column="1" Style="{StaticResource ColSplitter}"/>

    <!-- 右：選取夾之條目（右欄頂[清除全部]，比照歷史分頁；Issue #42） -->
    <Grid Grid.Column="2" Margin="4,8,10,10">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <!-- 條目工具列（Issue #52 名稱排序＋#104 時間排序；WrapPanel 換行——右欄壓窄時五鈕全可視可點） -->
      <WrapPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
        <Button x:Name="SortAscBtn" Content="A→Z" Style="{StaticResource GhostButton}"
                ToolTip="Sort entries in this folder A→Z by original text" Margin="0,0,6,4"/>
        <Button x:Name="SortDescBtn" Content="Z→A" Style="{StaticResource GhostButton}"
                ToolTip="Sort entries in this folder Z→A by original text" Margin="0,0,6,4"/>
        <Button x:Name="SortOldBtn" Content="Old→New" Style="{StaticResource GhostButton}"
                ToolTip="Sort entries in this folder oldest→newest by added time" Margin="0,0,6,4"/>
        <Button x:Name="SortNewBtn" Content="New→Old" Style="{StaticResource GhostButton}"
                ToolTip="Sort entries in this folder newest→oldest by added time" Margin="0,0,6,4"/>
        <Button x:Name="ClearPracticeBtn" Content="Clear Practice"
                ToolTip="Reset every pronunciation-practice score box in this folder (notes are kept)"
                Foreground="#8A2B2B" Style="{StaticResource GhostButton}" Margin="0,0,0,4"/>
      </WrapPanel>
      <!-- 發音練習操作提示（spec#10；自成一列、全寬置左，不與排序鈕重疊） -->
      <TextBlock Grid.Row="1" HorizontalAlignment="Left" Foreground="#8A5A6D" FontSize="11.5"
                 Margin="2,0,0,6" TextTrimming="CharacterEllipsis"
                 ToolTip="Play reads the sentence; press and hold the mic to record your voice, then release to score. The box shows your best.">
        Play&#160;&#9654;&#160;&#183;&#160;hold&#160;the&#160;mic&#160;to&#160;record&#160;&#183;&#160;score box = your best
      </TextBlock>
      <Grid Grid.Row="2">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,0,4,0">
          <StackPanel x:Name="EntryPanel"/>
        </ScrollViewer>
        <TextBlock x:Name="EmptyHint" Text="No notes in this folder yet. Use “Add to My Notes” on a result or history entry to save one; right-click folders on the left to manage, drag to move."
                   Foreground="#9A6A82" FontSize="13" TextWrapping="Wrap" MaxWidth="320"
                   TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
