<UserControl x:Class="ScreenTrans.Present.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Issue #79：資訊卡 + 更新紀錄（ChangeLog）可捲動區 -->
  <Grid Margin="16" HorizontalAlignment="Center" MaxWidth="640">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Style="{StaticResource Card}" Width="440" HorizontalAlignment="Center" Padding="20" Margin="0,0,0,10">
      <StackPanel HorizontalAlignment="Center">
        <Image Source="pack://application:,,,/assets/icon.png" Width="64" Height="64" Margin="0,2,0,8"/>
        <TextBlock Text="ScreenTrans" FontSize="20" FontWeight="SemiBold"
                   Foreground="{StaticResource PinkText}" HorizontalAlignment="Center"/>
        <TextBlock x:Name="VersionText" FontSize="13" Foreground="{StaticResource PinkSub}"
                   HorizontalAlignment="Center" Margin="0,4,0,10"/>
        <TextBlock Text="Instant English lookup for game screens" FontSize="12.5" Foreground="{StaticResource PinkSub}"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="© 2026 Carlton Chen. All rights reserved." FontSize="12.5"
                   Foreground="{StaticResource PinkSub}" HorizontalAlignment="Center" Margin="0,8,0,2"/>
        <TextBlock Text="Contact: carlton0521@gmail.com" FontSize="12.5"
                   Foreground="{StaticResource PinkSub}" HorizontalAlignment="Center"/>
        <TextBlock Text="Recognition &amp; translation by OpenAI; speech by Windows built-in voices." FontSize="11.5"
                   Foreground="#9A6A82" HorizontalAlignment="Center" Margin="0,10,0,0"/>
        <!-- 更新區（Issue #51）：僅 Velopack 安裝形態顯示；dev 裸跑隱藏 -->
        <StackPanel x:Name="UpdatePanel" Orientation="Horizontal" HorizontalAlignment="Center"
                    Margin="0,12,0,0" Visibility="Collapsed">
          <TextBlock x:Name="UpdateStatusText" FontSize="12.5" Foreground="{StaticResource PinkSub}"
                     VerticalAlignment="Center" Margin="0,0,8,0"/>
          <Button x:Name="CheckUpdateBtn" Content="Check for Updates" Style="{StaticResource GhostButton}"/>
          <Button x:Name="RestartUpdateBtn" Content="Restart to Update" Style="{StaticResource PinkButton}"
                  Visibility="Collapsed"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- 更新紀錄（ChangeLog）：嵌入資源、唯讀可捲動可選取（Issue #79） -->
    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Change Log" FontWeight="SemiBold"
                   Foreground="{StaticResource PinkText}" Margin="0,0,0,6"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <TextBox x:Name="ChangeLogBox" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                   TextWrapping="Wrap" FontSize="12" Foreground="#3A2C33" IsTabStop="False"
                   Padding="0"/>
        </ScrollViewer>
      </Grid>
    </Border>
  </Grid>
</UserControl>
