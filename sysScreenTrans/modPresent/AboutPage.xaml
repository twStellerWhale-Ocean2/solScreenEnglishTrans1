<UserControl x:Class="ScreenTrans.Present.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Border Style="{StaticResource Card}" Width="440"
            HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20">
      <StackPanel HorizontalAlignment="Center">
        <Image Source="pack://application:,,,/assets/icon.png" Width="72" Height="72" Margin="0,4,0,10"/>
        <TextBlock Text="ScreenTrans" FontSize="20" FontWeight="SemiBold"
                   Foreground="{StaticResource PinkText}" HorizontalAlignment="Center"/>
        <TextBlock x:Name="VersionText" FontSize="13" Foreground="{StaticResource PinkSub}"
                   HorizontalAlignment="Center" Margin="0,4,0,12"/>
        <TextBlock Text="遊戲畫面英文即時查詢工具" FontSize="12.5" Foreground="{StaticResource PinkSub}"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="© 2026 Carlton Chen. 保留一切權利。" FontSize="12.5"
                   Foreground="{StaticResource PinkSub}" HorizontalAlignment="Center" Margin="0,10,0,2"/>
        <TextBlock Text="聯絡：carlton0521@gmail.com" FontSize="12.5"
                   Foreground="{StaticResource PinkSub}" HorizontalAlignment="Center"/>
        <TextBlock Text="辨識翻譯使用 OpenAI；朗讀使用 Windows 內建語音。" FontSize="11.5"
                   Foreground="#9A6A82" HorizontalAlignment="Center" Margin="0,12,0,0"/>
        <!-- 更新區（Issue #51）：僅 Velopack 安裝形態顯示；dev 裸跑隱藏 -->
        <StackPanel x:Name="UpdatePanel" Orientation="Horizontal" HorizontalAlignment="Center"
                    Margin="0,14,0,0" Visibility="Collapsed">
          <TextBlock x:Name="UpdateStatusText" FontSize="12.5" Foreground="{StaticResource PinkSub}"
                     VerticalAlignment="Center" Margin="0,0,8,0"/>
          <Button x:Name="CheckUpdateBtn" Content="檢查更新" Style="{StaticResource GhostButton}"/>
          <Button x:Name="RestartUpdateBtn" Content="立即重啟更新" Style="{StaticResource PinkButton}"
                  Visibility="Collapsed"/>
        </StackPanel>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
