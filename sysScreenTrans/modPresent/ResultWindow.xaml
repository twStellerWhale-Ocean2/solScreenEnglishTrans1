<Window x:Class="ScreenTrans.Present.ResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Query Result"
        Icon="pack://application:,,,/assets/app.ico"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize"
        ShowInTaskbar="True" Topmost="True"
        Background="{StaticResource PinkBg}"
        Width="560" Height="400" MinWidth="320" MinHeight="220"
        WindowStartupLocation="CenterScreen">
  <!-- Issue #59：改標準表單——標準標題列（OS 字型/標題）＋標準邊框拖拉縮放（ResizeMode=CanResize）＋
       ShowInTaskbar=True（失焦後仍有工作列按鈕可尋、不再像被隱藏）。移除原自訂 WindowStyle=None 卡片、
       自訂標題列/關閉鈕/縮放握把（改由 OS 標準 chrome 提供）。字型比照主視窗（系統預設）。 -->
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- 浮水印底圖（兩位女孩，極淡、不擋點擊） -->
    <Image Grid.Row="0" Grid.RowSpan="2" Source="pack://application:,,,/assets/icon.png"
           Opacity="0.10" Stretch="Uniform" IsHitTestVisible="False"
           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20"/>

    <!-- 內容區：過長可捲動 -->
    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel x:Name="BodyPanel" Margin="18,14,18,10"/>
    </ScrollViewer>

    <!-- 底部工具列（Issue #34）：加入我的筆記＋自動加入筆記；下方為預設資料夾/底色（Issue #55） -->
    <Grid Grid.Row="1">
      <Border Height="1" Background="#F4C2D0" VerticalAlignment="Top"/>
      <StackPanel Margin="16,10,16,12">
        <StackPanel Orientation="Horizontal">
          <Button x:Name="AddNoteBtn" Cursor="Hand" ToolTip="Add to My Notes">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border x:Name="bg" CornerRadius="8" Background="#E9F6EE" BorderBrush="#C9E6D3"
                        BorderThickness="1" Padding="12,5">
                  <TextBlock Text="＋ Add to My Notes" FontSize="13.5" Foreground="#2F6F4A"/>
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bg" Property="Background" Value="#D9EFE0"/>
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Button.Template>
          </Button>
          <CheckBox x:Name="AutoAddChk" Content="Auto-add to Notes" Margin="14,0,0,0"
                    VerticalAlignment="Center" Foreground="#8A5A6D" FontSize="13"/>
        </StackPanel>
        <!-- #55：加入至哪個資料夾＋底色（此列兼作「設定預設」與「臨時調整」；智能配色下自動預選 AI 建議色） -->
        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
          <TextBlock Text="Add to" VerticalAlignment="Center" Foreground="#8A5A6D" FontSize="12.5" Margin="0,0,6,0"/>
          <ComboBox x:Name="FolderCombo" MinWidth="118" MaxWidth="180" FontSize="12.5" VerticalAlignment="Center"/>
          <TextBlock Text="Color" VerticalAlignment="Center" Foreground="#8A5A6D" FontSize="12.5" Margin="14,0,6,0"/>
          <StackPanel x:Name="SwatchRow" Orientation="Horizontal" VerticalAlignment="Center"/>
        </StackPanel>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
