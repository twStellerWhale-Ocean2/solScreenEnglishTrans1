<Window x:Class="ScreenTrans.Present.DockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenTrans" Width="360" Height="264"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True" Background="#F4F6F9"
        Icon="pack://application:,,,/assets/app.ico">
  <Grid Margin="18,16,18,16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- 金鑰狀態 -->
    <TextBlock x:Name="KeyStatusText" Grid.Row="0"
               Text="● 金鑰已備妥（OPENAI_API_KEY）"
               FontSize="15" Foreground="#2E3A48" Margin="0,0,0,4"/>

    <!-- 喚起快捷鍵 -->
    <TextBlock x:Name="HotkeyText" Grid.Row="1"
               Text="喚起快捷鍵：Alt + L"
               FontSize="13" Foreground="#66727F" Margin="0,0,0,14"/>

    <!-- 維運按鈕 -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,14">
      <Button x:Name="HistoryBtn" Content="查詢歷史" Width="96" Height="34"
              Background="#5A7FBF" Foreground="White" BorderThickness="0"
              FontSize="13" FontWeight="SemiBold" Cursor="Hand"/>
      <Button x:Name="SettingsBtn" Content="設定…" Width="84" Height="34" Margin="8,0,0,0"
              Background="#3F6FB0" Foreground="White" BorderThickness="0"
              FontSize="13" FontWeight="SemiBold" Cursor="Hand"/>
      <Button x:Name="ExitBtn" Content="結束" Width="72" Height="34" Margin="8,0,0,0"
              Background="#E7EBF1" Foreground="#3A4757" BorderThickness="0"
              FontSize="13" FontWeight="SemiBold" Cursor="Hand"/>
    </StackPanel>

    <!-- 使用提示 -->
    <Border Grid.Row="3" Background="#EEF4FB" BorderBrush="#D6E4F4" BorderThickness="1"
            CornerRadius="7" Padding="10,8" VerticalAlignment="Top">
      <TextBlock x:Name="HintText" TextWrapping="Wrap" FontSize="12" Foreground="#4A6480"
                 Text="按快捷鍵框選畫面英文即查詢。關閉此視窗＝收合到工作列／系統匣，程式仍常駐、不會結束（可隨時從工作列或 Alt+Tab 找回）。"/>
    </Border>
  </Grid>
</Window>
