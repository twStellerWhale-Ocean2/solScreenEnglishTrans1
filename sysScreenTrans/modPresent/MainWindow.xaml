<Window x:Class="ScreenTrans.Present.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenTrans" Width="680" Height="540" MinWidth="560" MinHeight="440"
        ShowInTaskbar="True" WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/assets/app.ico" Background="{StaticResource PinkBg}">
  <Window.Resources>
    <!-- 分頁鈕：圖示在上、文字在下（USR 回饋，Issue #34）；圖示採 Segoe MDL2 Assets 系統字圖（Issue #38） -->
    <Style x:Key="TabButton" TargetType="RadioButton">
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Margin" Value="4,0,0,0"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border x:Name="bg" CornerRadius="9" Background="Transparent" Padding="8,7" Width="78">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{TemplateBinding Tag}" FontFamily="Segoe MDL2 Assets" FontSize="18"
                           Foreground="{StaticResource PinkText}" HorizontalAlignment="Center"/>
                <ContentPresenter HorizontalAlignment="Center" Margin="0,4,0,0"
                                  TextElement.FontSize="11.5" TextElement.Foreground="#8A5A6D"/>
              </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="bg" Property="Background" Value="{StaticResource PinkAccent}"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bg" Property="Background" Value="{StaticResource PinkTint}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <!-- logo 背景浮水印（Issue #71：提高不透明度、放大，讓小女孩明顯一點；仍不擋操作） -->
    <Image Source="pack://application:,,,/assets/icon.png" Opacity="0.14" Stretch="Uniform"
           IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40"/>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- 功能列分頁（圖示＋文字；標題僅在 OS 標題列、內容區不重複——Issue #38 Windows 慣例） -->
      <Grid Grid.Row="0">
        <StackPanel Orientation="Horizontal" Margin="12,10,0,6">
          <RadioButton x:Name="TabContext" Style="{StaticResource TabButton}" GroupName="MainTabs" Tag="&#xEB9F;" Content="情境"/>
          <RadioButton x:Name="TabNotes" Style="{StaticResource TabButton}" GroupName="MainTabs" Tag="&#xE70B;" Content="筆記" IsChecked="True"/>
          <RadioButton x:Name="TabHistory" Style="{StaticResource TabButton}" GroupName="MainTabs" Tag="&#xE81C;" Content="歷史"/>
          <RadioButton x:Name="TabOptions" Style="{StaticResource TabButton}" GroupName="MainTabs" Tag="&#xE713;" Content="選項"/>
          <RadioButton x:Name="TabAbout" Style="{StaticResource TabButton}" GroupName="MainTabs" Tag="&#xE946;" Content="關於"/>
        </StackPanel>
        <Border Height="1" Background="{StaticResource PinkAccent}" VerticalAlignment="Bottom"/>
      </Grid>

      <!-- 內容區 -->
      <ContentControl x:Name="Host" Grid.Row="1" Margin="0"/>

      <!-- 底部狀態列（Windows 慣例：狀態文字置底——Issue #38） -->
      <StatusBar Grid.Row="2" Background="{StaticResource PinkTint}" BorderBrush="{StaticResource PinkAccent}" BorderThickness="0,1,0,0">
        <StatusBarItem>
          <TextBlock x:Name="KeyStatusText" FontSize="12" Foreground="#2E7D46" Margin="6,0,0,0"/>
        </StatusBarItem>
        <Separator Background="{StaticResource PinkAccent}"/>
        <StatusBarItem>
          <TextBlock x:Name="HotkeyText" FontSize="12" Foreground="#8A5A6D"/>
        </StatusBarItem>
        <Separator x:Name="UpdateSeparator" Background="{StaticResource PinkAccent}" Visibility="Collapsed"/>
        <StatusBarItem>
          <!-- 更新就緒提示（Issue #51）：新版靜默下載完成才顯示，平時隱藏 -->
          <TextBlock x:Name="UpdateText" FontSize="12" Foreground="#2F6FED" Visibility="Collapsed"/>
        </StatusBarItem>
      </StatusBar>
    </Grid>
  </Grid>
</Window>
