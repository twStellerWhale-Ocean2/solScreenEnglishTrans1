<Window x:Class="ScreenTrans.Present.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenTrans" Width="680" Height="540" MinWidth="560" MinHeight="440"
        ShowInTaskbar="True" WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/assets/app.ico" Background="{StaticResource PinkBg}">
  <Window.Resources>
    <!-- 分頁鈕：圖示在上、文字在下（USR 回饋，Issue #34） -->
    <Style x:Key="TabButton" TargetType="RadioButton">
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Margin" Value="4,0,0,0"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border x:Name="bg" CornerRadius="9" Background="Transparent" Padding="8,6" Width="78">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{TemplateBinding Tag}" FontFamily="Segoe UI Emoji" FontSize="20"
                           HorizontalAlignment="Center"/>
                <ContentPresenter HorizontalAlignment="Center" Margin="0,2,0,0"
                                  TextElement.FontSize="11.5" TextElement.Foreground="#8A5A6D"/>
              </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="bg" Property="Background" Value="{StaticResource PinkAccent}"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bg" Property="Background" Value="{StaticResource PinkTint}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <!-- logo 背景浮水印（極淡、不擋操作） -->
    <Image Source="pack://application:,,,/assets/icon.png" Opacity="0.05" Stretch="Uniform"
           IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="80"/>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- 標題／金鑰狀態 -->
      <StackPanel Grid.Row="0" Background="{StaticResource PinkTint}">
        <TextBlock Text="ScreenTrans" FontSize="15" FontWeight="SemiBold"
                   Foreground="{StaticResource PinkText}" Margin="16,8,0,0"/>
        <TextBlock x:Name="StatusText" FontSize="12" Foreground="#2E7D46" Margin="16,2,0,8"/>
      </StackPanel>

      <!-- 功能列分頁（圖示＋文字） -->
      <Grid Grid.Row="1">
        <StackPanel Orientation="Horizontal" Margin="12,8,0,6">
          <RadioButton x:Name="TabNotes" Style="{StaticResource TabButton}" GroupName="MainTabs" Tag="📒" Content="筆記" IsChecked="True"/>
          <RadioButton x:Name="TabHistory" Style="{StaticResource TabButton}" GroupName="MainTabs" Tag="🕘" Content="歷史"/>
          <RadioButton x:Name="TabContext" Style="{StaticResource TabButton}" GroupName="MainTabs" Tag="💬" Content="情境"/>
          <RadioButton x:Name="TabOptions" Style="{StaticResource TabButton}" GroupName="MainTabs" Tag="⚙️" Content="選項"/>
          <RadioButton x:Name="TabAbout" Style="{StaticResource TabButton}" GroupName="MainTabs" Tag="ℹ️" Content="關於"/>
        </StackPanel>
        <Border Height="1" Background="{StaticResource PinkAccent}" VerticalAlignment="Bottom"/>
      </Grid>

      <!-- 內容區 -->
      <ContentControl x:Name="Host" Grid.Row="2" Margin="0"/>
    </Grid>
  </Grid>
</Window>
